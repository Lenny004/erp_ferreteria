<UserControl
    x:Class="Ferreteria.PuntoVenta.Views.Inventario.MovimientosView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Ferreteria.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!-- Kardex -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Entradas y Kardex" Style="{StaticResource AppPanelTitleStyle}" />
                <TextBlock Text="Movimientos de inventario recientes" Style="{StaticResource AppPanelSubtitleStyle}" />
            </StackPanel>
            <Button Grid.Row="1" HorizontalAlignment="Left" Style="{StaticResource AppSecondaryWideButtonStyle}"
                    Click="OnActualizarClick" Margin="0,0,0,12">
                <TextBlock Text="ACTUALIZAR" Foreground="{StaticResource AppBlanco}" FontWeight="Bold" />
            </Button>
            <Border
                Grid.Row="2"
                Background="{StaticResource AppAzulMedio}"
                BorderBrush="{StaticResource AppAzulClaro}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppRadius_MD}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Style="{StaticResource AppGridHeaderStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FECHA" Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="1" Text="CODIGO" Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="2" Text="TIPO" Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="3" Text="PRODUCTO" Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="4" Text="CANT." Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="5" Text="SALDO" Style="{StaticResource AppGridHeaderTextStyle}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <TextBlock
                            x:Name="EmptyStateText"
                            Text="Sin movimientos para mostrar."
                            Style="{StaticResource AppTableCellStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ItemsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource AppDataGridRowStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd/MM HH:mm'}" Style="{StaticResource AppTableCellStyle}" />
                                                <TextBlock Grid.Column="1" Text="{Binding ProductCode}" Style="{StaticResource AppTableCellStyle}" Foreground="{StaticResource AppRojo}" />
                                                <TextBlock Grid.Column="2" Text="{Binding MovementType}" Style="{StaticResource AppTableCellStyle}" />
                                                <TextBlock Grid.Column="3" Text="{Binding ProductDescription}" Style="{StaticResource AppTableCellStyle}" />
                                                <TextBlock Grid.Column="4" Text="{Binding Quantity}" Style="{StaticResource AppTableCellStyle}" />
                                                <TextBlock Grid.Column="5" Text="{Binding StockAfter}" Style="{StaticResource AppTableCellStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Formulario de movimiento -->
        <Border
            Grid.Column="1"
            Background="{StaticResource AppAzulMedio}"
            BorderBrush="{StaticResource AppAzulClaro}"
            BorderThickness="1"
            CornerRadius="{StaticResource AppRadius_MD}"
            Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Registrar movimiento" Style="{StaticResource AppPanelTitleStyle}" Margin="0,0,0,12" />

                    <TextBlock Text="Producto *" Style="{StaticResource AppCardLabelStyle}" />
                    <ComboBox x:Name="ProductCombo" Style="{StaticResource AppFieldComboBoxStyle}"
                              DisplayMemberPath="Display" SelectedValuePath="Id"
                              IsEditable="True" IsTextSearchEnabled="True"
                              SelectionChanged="OnProductSelected" Margin="0,4,0,10" />

                    <TextBlock x:Name="CurrentStockText" Text="Stock actual: -"
                               Foreground="{StaticResource AppInfo}" Margin="0,0,0,10" />

                    <TextBlock Text="Tipo de movimiento *" Style="{StaticResource AppCardLabelStyle}" />
                    <ComboBox x:Name="TypeCombo" Style="{StaticResource AppFieldComboBoxStyle}"
                              SelectedIndex="0" SelectionChanged="OnTypeChanged" Margin="0,4,0,10">
                        <ComboBoxItem Content="Entrada por compra" Tag="ENTRADA_COMPRA" />
                        <ComboBoxItem Content="Entrada por devolucion" Tag="ENTRADA_DEVOLUCION" />
                        <ComboBoxItem Content="Ajuste (fijar stock)" Tag="AJUSTE" />
                    </ComboBox>

                    <TextBlock x:Name="QuantityLabel" Text="Cantidad a ingresar *" Style="{StaticResource AppCardLabelStyle}" />
                    <TextBox x:Name="QuantityBox" Text="0" Style="{StaticResource AppFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <StackPanel x:Name="CostPanel">
                        <TextBlock Text="Costo unitario" Style="{StaticResource AppCardLabelStyle}" />
                        <TextBox x:Name="UnitCostBox" Text="0" Style="{StaticResource AppFieldTextBoxStyle}" Margin="0,4,0,10" />
                    </StackPanel>

                    <TextBlock Text="Motivo" Style="{StaticResource AppCardLabelStyle}" />
                    <TextBox x:Name="ReasonBox" Style="{StaticResource AppFieldTextBoxStyle}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="50" Margin="0,4,0,10" />

                    <TextBlock x:Name="FormErrorText" Foreground="{StaticResource AppError}"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,8" />

                    <Button Style="{StaticResource AppPrimaryWideButtonStyle}" Click="OnRegistrarClick">
                        <TextBlock Text="REGISTRAR" Foreground="{StaticResource AppBlanco}" FontWeight="Bold" />
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
