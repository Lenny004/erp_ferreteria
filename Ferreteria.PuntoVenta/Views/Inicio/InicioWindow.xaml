<Window
    x:Class="Ferreteria.PuntoVenta.Views.Inicio.InicioWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ferreteria — Inicio"
    Height="560"
    Width="760"
    MinHeight="480"
    MinWidth="680"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Botón de módulo principal -->
            <Style
                x:Key="EstiloBotonModulo"
                TargetType="Button">
                <Setter
                    Property="Width"
                    Value="160" />
                <Setter
                    Property="Height"
                    Value="160" />
                <Setter
                    Property="Foreground"
                    Value="{StaticResource AppBlanco}" />
                <Setter
                    Property="BorderThickness"
                    Value="0" />
                <Setter
                    Property="Cursor"
                    Value="Hand" />
                <Setter
                    Property="Background"
                    Value="{StaticResource GradienteBoton}" />
                <Setter
                    Property="Template">
                    <Setter.Value>
                        <ControlTemplate
                            TargetType="Button">
                            <Border
                                x:Name="bordePrincipal"
                                CornerRadius="{StaticResource AppRadius_XL}"
                                Background="{TemplateBinding Background}">
                                <Border.Effect>
                                    <DropShadowEffect
                                        Color="#C23D3D"
                                        BlurRadius="20"
                                        ShadowDepth="0"
                                        Opacity="0.3" />
                                </Border.Effect>
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger
                                    Property="IsMouseOver"
                                    Value="True">
                                    <Setter
                                        TargetName="bordePrincipal"
                                        Property="Background"
                                        Value="{StaticResource GradienteBotonHover}" />
                                    <Setter
                                        TargetName="bordePrincipal"
                                        Property="BorderBrush"
                                        Value="{StaticResource AppBlanco}" />
                                </Trigger>
                                <Trigger
                                    Property="IsPressed"
                                    Value="True">
                                    <Setter
                                        TargetName="bordePrincipal"
                                        Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform
                                                ScaleX="0.96"
                                                ScaleY="0.96"
                                                CenterX="80"
                                                CenterY="80" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Etiqueta de botón de módulo -->
            <Style
                x:Key="EstiloEtiquetaBoton"
                TargetType="TextBlock">
                <Setter
                    Property="FontFamily"
                    Value="{StaticResource AppFontFamily}" />
                <Setter
                    Property="FontSize"
                    Value="{StaticResource AppFontSize_XL}" />
                <Setter
                    Property="FontWeight"
                    Value="{StaticResource AppFontWeight_Medium}" />
                <Setter
                    Property="Foreground"
                    Value="{StaticResource AppBlanco}" />
                <Setter
                    Property="HorizontalAlignment"
                    Value="Center" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <!-- Fondo oscuro con gradiente -->
        <Border
            Background="{StaticResource FondoVentana}" />
        <!-- Línea de acento roja superior -->
        <Rectangle
            Height="3"
            VerticalAlignment="Top"
            Fill="{StaticResource AppRojo}"
            Opacity="0.8" />
        <!-- Botones de ventana (minimizar, maximizar, cerrar) -->
        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,0,8,0">
            <Button
                Content="&#x2014;"
                Style="{StaticResource AppWindowButtonStyle}"
                Click="OnMinimizarClick" />
            <Button
                Content="&#x25A1;"
                Style="{StaticResource AppWindowButtonStyle}"
                Click="OnMaximizarClick" />
            <Button
                Content="&#x2715;"
                Style="{StaticResource AppHeaderCloseHover}"
                Click="OnCerrarClick" />
        </StackPanel>
        <!-- Contenido centrado -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="560">
            <!-- ── LOGO / MARCA ── -->
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock
                        Text="FERRETERIA"
                        FontSize="{StaticResource AppFontSize_Display}"
                        FontWeight="{StaticResource AppFontWeight_Bold}"
                        Foreground="{StaticResource AppBlanco}" />
                    <Rectangle
                        Height="4"
                        Fill="{StaticResource AppRojo}"
                        RadiusX="2"
                        RadiusY="2" />
                    <TextBlock
                        Text="EL SALVADOR  ·  PUNTO DE VENTA"
                        FontSize="{StaticResource AppFontSize_MD}"
                        FontWeight="{StaticResource AppFontWeight_Light}"
                        Foreground="{StaticResource AppBlanco}"
                        Margin="2,2,0,0"
                        Width="207" />
                </StackPanel>
            </StackPanel>
            <!-- Separador -->
            <Grid
                Margin="0,24,0,32">
                <Rectangle
                    Height="2"
                    Fill="{StaticResource AppAzulClaro}"
                    VerticalAlignment="Center"
                    RadiusX="2"
                    RadiusY="2" />
                <Border
                    Background="{StaticResource AppAzulMedio}"
                    HorizontalAlignment="Center"
                    Padding="16,0">
                    <TextBlock
                        Text="SELECCIONA UN MÓDULO"
                        FontSize="{StaticResource AppFontSize_MD}"
                        FontWeight="{StaticResource AppFontWeight_Light}"
                        Foreground="{StaticResource AppBlanco}" />
                </Border>
            </Grid>
            <!-- ── BOTONES DE MÓDULO ── -->
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,0,0,40">
                <!-- Ventas -->
                <StackPanel
                    Margin="0,0,32,0">
                    <Button
                        Name="BtnVentas"
                        Style="{StaticResource EstiloBotonModulo}"
                        Click="OnVentasClick"
                        Height="124">
                        <StackPanel>
                            <Image
                                Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/register.png"
                                Width="48"
                                Height="48"
                                Margin="0,0,0,8" />
                            <TextBlock
                                Style="{StaticResource EstiloEtiquetaBoton}"
                                Text="VENTAS" />
                        </StackPanel>
                    </Button>
                    <TextBlock
                        Text="Órdenes y facturación"
                        FontSize="{StaticResource AppFontSize_XS}"
                        Foreground="{StaticResource AppGrisClaro}"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0" />
                </StackPanel>
                <!-- Inventario -->
                <StackPanel>
                    <Button
                        Name="BtnInventario"
                        Style="{StaticResource EstiloBotonModulo}"
                        Click="OnInventarioClick"
                        Height="124">
                        <StackPanel>
                            <Image
                                Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/confecciones.png"
                                Width="48"
                                Height="48"
                                Margin="0,0,0,8" />
                            <TextBlock
                                Style="{StaticResource EstiloEtiquetaBoton}"
                                Text="INVENTARIO" />
                        </StackPanel>
                    </Button>
                    <TextBlock
                        Text="Stock y movimientos"
                        FontSize="{StaticResource AppFontSize_XS}"
                        Foreground="{StaticResource AppGrisClaro}"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0" />
                </StackPanel>
            </StackPanel>
            <!-- ── PIE: versión ── -->
            <TextBlock
                Text="v1.0.0-MVP · 2026"
                FontSize="{StaticResource AppFontSize_XS}"
                Foreground="{StaticResource AppGris}"
                HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
