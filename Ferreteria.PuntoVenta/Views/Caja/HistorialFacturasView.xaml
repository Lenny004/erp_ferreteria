<UserControl
    x:Class="Ferreteria.PuntoVenta.Views.Caja.HistorialFacturasView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Ferreteria.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="420" />
            </Grid.RowDefinitions>
            <Grid
                Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock
                        Text="Historial de Facturas"
                        Style="{StaticResource AppPanelTitleStyle}" />
                    <TextBlock
                        Text="Consulta y reimpresion de DTE emitidos"
                        Style="{StaticResource AppPanelSubtitleStyle}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Style="{StaticResource AppPrimaryWideButtonStyle}">
                    <TextBlock
                        Text="REIMPRIMIR"
                        Foreground="{StaticResource AppBlanco}"
                        FontWeight="Bold" />
                </Button>
            </Grid>
            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,0,0,16">
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Emitidas hoy"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            x:Name="IssuedTodayText"
                            Text="0"
                            Style="{StaticResource AppCardValueStyle}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Total facturado"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            x:Name="TotalBilledText"
                            Text="$0.00"
                            Style="{StaticResource AppCardValueStyle}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Contingencia"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="0"
                            Style="{StaticResource AppCardValueStyle}"
                            Foreground="{StaticResource AppWarning}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Reimpresiones"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            x:Name="ShownText"
                            Text="0"
                            Style="{StaticResource AppCardValueStyle}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid
                Grid.Row="2"
                Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="140" />
                    <ColumnDefinition
                        Width="140" />
                    <ColumnDefinition
                        Width="140" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource AppFieldTextBoxStyle}"
                    helpers:WatermarkService.Watermark="Buscar cliente, control u orden"
                    TextChanged="OnSearchChanged" />
                <ComboBox
                    Grid.Column="1"
                    Style="{StaticResource AppFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="0">
                    <ComboBoxItem
                        Content="Hoy" />
                    <ComboBoxItem
                        Content="Semana" />
                    <ComboBoxItem
                        Content="Mes" />
                </ComboBox>
                <ComboBox
                    Grid.Column="2"
                    Style="{StaticResource AppFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="0">
                    <ComboBoxItem
                        Content="Estado MH" />
                    <ComboBoxItem
                        Content="Procesado" />
                    <ComboBoxItem
                        Content="Pendiente" />
                </ComboBox>
                <ComboBox
                    Grid.Column="3"
                    Style="{StaticResource AppFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="0">
                    <ComboBoxItem
                        Content="Tipo DTE" />
                    <ComboBoxItem
                        Content="01" />
                    <ComboBoxItem
                        Content="03" />
                </ComboBox>
            </Grid>
            <Border
                Grid.Row="3"
                Background="{StaticResource AppAzulMedio}"
                BorderBrush="{StaticResource AppAzulClaro}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppRadius_MD}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition
                            Height="40" />
                        <RowDefinition
                            Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Style="{StaticResource AppGridHeaderStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="100" />
                            <ColumnDefinition
                                Width="160" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="80" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="100" />
                            <ColumnDefinition
                                Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="FECHA"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="NO. CONTROL"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="2"
                            Text="CLIENTE"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="3"
                            Text="DTE"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="4"
                            Text="PAGO"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="5"
                            Text="TOTAL"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="6"
                            Text="ESTADO"
                            Style="{StaticResource AppGridHeaderTextStyle}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <TextBlock
                            x:Name="EmptyStateText"
                            Text="Sin ventas completadas para mostrar."
                            Style="{StaticResource AppTableCellStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <ListBox
                            x:Name="SalesListBox"
                            Background="Transparent"
                            BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AppDataGridRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DateText}" Style="{StaticResource AppTableCellStyle}" />
                                            <TextBlock Grid.Column="1" Text="{Binding ControlNumberText}" Style="{StaticResource AppTableCellStyle}" Foreground="{StaticResource AppRojo}" />
                                            <TextBlock Grid.Column="2" Text="{Binding CustomerDisplayName}" Style="{StaticResource AppTableCellStyle}" />
                                            <TextBlock Grid.Column="3" Text="{Binding ChannelLabel}" Style="{StaticResource AppTableCellStyle}" />
                                            <TextBlock Grid.Column="4" Text="{Binding PaymentMethod}" Style="{StaticResource AppTableCellStyle}" />
                                            <TextBlock Grid.Column="5" Text="{Binding TotalText}" Style="{StaticResource AppTableCellStyle}" />
                                            <Border Grid.Column="6" Style="{StaticResource AppBadgeStyle}" Background="{StaticResource AppAzulClaro}">
                                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource AppBlanco}" FontSize="{StaticResource AppFontSize_XS}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
