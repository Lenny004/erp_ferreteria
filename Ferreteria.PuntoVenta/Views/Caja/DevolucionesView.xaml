<UserControl
    x:Class="Ferreteria.PuntoVenta.Views.Caja.DevolucionesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Ferreteria.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="500" />
            </Grid.RowDefinitions>
            <StackPanel
                Margin="0,0,0,16">
                <TextBlock
                    Text="Devoluciones"
                    Style="{StaticResource AppPanelTitleStyle}" />
                <TextBlock
                    Text="Notas de credito DTE-05, devoluciones y anulaciones"
                    Style="{StaticResource AppPanelSubtitleStyle}" />
            </StackPanel>
            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,0,0,16">
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Paso 1"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="Buscar factura"
                            Style="{StaticResource AppCardValueStyle}"
                            FontSize="{StaticResource AppFontSize_LG}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Paso 2"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="Seleccionar items"
                            Style="{StaticResource AppCardValueStyle}"
                            FontSize="{StaticResource AppFontSize_LG}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Paso 3"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="Motivo"
                            Style="{StaticResource AppCardValueStyle}"
                            FontSize="{StaticResource AppFontSize_LG}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Paso 4"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="Emitir DTE-05"
                            Style="{StaticResource AppCardValueStyle}"
                            FontSize="{StaticResource AppFontSize_LG}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid
                Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="1.3*" />
                    <ColumnDefinition
                        Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Factura original"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBox
                            Style="{StaticResource AppFieldTextBoxStyle}"
                            helpers:WatermarkService.Watermark="No. control, cliente, NIT o fecha"
                            Margin="0,8,0,12" />
                        <Button
                            Style="{StaticResource AppSecondaryWideButtonStyle}"
                            Margin="0,0,0,16">
                            <TextBlock
                                Text="BUSCAR"
                                Foreground="{StaticResource AppBlanco}"
                                FontWeight="Bold" />
                        </Button>
                        <TextBlock
                            Text="Productos a devolver"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <Border
                            Style="{StaticResource AppDataGridRowStyle}"
                            Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="*" />
                                    <ColumnDefinition
                                        Width="90" />
                                    <ColumnDefinition
                                        Width="90" />
                                    <ColumnDefinition
                                        Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="Cable galvanizado acero #3"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="5.50"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="2.00"
                                    Style="{StaticResource AppTableCellStyle}"
                                    Foreground="{StaticResource AppWarning}" />
                                <TextBlock
                                    Grid.Column="3"
                                    Text="$25.00"
                                    Style="{StaticResource AppTableCellStyle}" />
                            </Grid>
                        </Border>
                        <Border
                            Style="{StaticResource AppDataGridRowStyle}"
                            Background="{StaticResource AppAzulFilaAlt}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="*" />
                                    <ColumnDefinition
                                        Width="90" />
                                    <ColumnDefinition
                                        Width="90" />
                                    <ColumnDefinition
                                        Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="Boquilla acelerador #1"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="2"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="1"
                                    Style="{StaticResource AppTableCellStyle}"
                                    Foreground="{StaticResource AppWarning}" />
                                <TextBlock
                                    Grid.Column="3"
                                    Text="$7.10"
                                    Style="{StaticResource AppTableCellStyle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Style="{StaticResource AppStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Motivo obligatorio"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <ComboBox
                            Style="{StaticResource AppFieldComboBoxStyle}"
                            SelectedIndex="0"
                            Margin="0,8,0,8">
                            <ComboBoxItem
                                Content="Producto defectuoso" />
                            <ComboBoxItem
                                Content="Error de venta" />
                            <ComboBoxItem
                                Content="Cambio" />
                            <ComboBoxItem
                                Content="Anulacion total" />
                        </ComboBox>
                        <TextBox
                            Style="{StaticResource AppFieldTextBoxStyle}"
                            helpers:WatermarkService.Watermark="Observaciones"
                            Height="72"
                            Margin="0,0,0,18" />
                        <TextBlock
                            Text="Subtotal devuelto: $32.10"
                            Style="{StaticResource AppTableCellStyle}"
                            Margin="0,0,0,6" />
                        <TextBlock
                            Text="IVA: $4.17"
                            Style="{StaticResource AppTableCellStyle}"
                            Margin="0,0,0,6" />
                        <TextBlock
                            Text="Total credito: $36.27"
                            Foreground="{StaticResource AppWarning}"
                            FontSize="{StaticResource AppFontSize_XL}"
                            FontWeight="Bold"
                            Margin="14,8,0,22" />
                        <Button
                            Style="{StaticResource AppPrimaryWideButtonStyle}"
                            Width="190">
                            <TextBlock
                                Text="GENERAR NOTA"
                                Foreground="{StaticResource AppBlanco}"
                                FontWeight="Bold" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
