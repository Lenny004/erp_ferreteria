<UserControl
    x:Class="Ferreteria.PuntoVenta.Views.Caja.ImpresorasView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Ferreteria.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="470" />
            </Grid.RowDefinitions>
            <StackPanel
                Margin="0,0,0,16">
                <TextBlock
                    Text="Impresoras"
                    Style="{StaticResource AppPanelTitleStyle}" />
                <TextBlock
                    Text="Impresoras conectadas y configuracion de tickets"
                    Style="{StaticResource AppPanelSubtitleStyle}" />
            </StackPanel>
            <UniformGrid
                Grid.Row="1"
                Columns="3"
                Margin="0,0,0,16">
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Predeterminada"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="EPSON TM-T20"
                            Style="{StaticResource AppCardValueStyle}"
                            FontSize="{StaticResource AppFontSize_LG}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Ancho papel"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="80 mm"
                            Style="{StaticResource AppCardValueStyle}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource AppStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Estado"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBlock
                            Text="Lista"
                            Style="{StaticResource AppCardValueStyle}"
                            Foreground="{StaticResource AppSuccess}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid
                Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="1.4*" />
                    <ColumnDefinition
                        Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border
                    Background="{StaticResource AppAzulMedio}"
                    BorderBrush="{StaticResource AppAzulClaro}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppRadius_MD}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <Grid
                            Height="40"
                            Style="{StaticResource AppGridHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition
                                    Width="*" />
                                <ColumnDefinition
                                    Width="100" />
                                <ColumnDefinition
                                    Width="120" />
                                <ColumnDefinition
                                    Width="100" />
                                <ColumnDefinition
                                    Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Text="NOMBRE"
                                Style="{StaticResource AppGridHeaderTextStyle}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="CONEXION"
                                Style="{StaticResource AppGridHeaderTextStyle}" />
                            <TextBlock
                                Grid.Column="2"
                                Text="IP"
                                Style="{StaticResource AppGridHeaderTextStyle}" />
                            <TextBlock
                                Grid.Column="3"
                                Text="PAPEL"
                                Style="{StaticResource AppGridHeaderTextStyle}" />
                            <TextBlock
                                Grid.Column="4"
                                Text="ESTADO"
                                Style="{StaticResource AppGridHeaderTextStyle}" />
                        </Grid>
                        <Border
                            Style="{StaticResource AppDataGridRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="*" />
                                    <ColumnDefinition
                                        Width="100" />
                                    <ColumnDefinition
                                        Width="120" />
                                    <ColumnDefinition
                                        Width="100" />
                                    <ColumnDefinition
                                        Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="EPSON TM-T20"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="USB"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="-"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <TextBlock
                                    Grid.Column="3"
                                    Text="80mm"
                                    Style="{StaticResource AppTableCellStyle}" />
                                <Border
                                    Grid.Column="4"
                                    Style="{StaticResource AppBadgeStyle}"
                                    Background="{StaticResource AppAzulClaro}">
                                    <TextBlock
                                        Text="DEFAULT"
                                        Foreground="{StaticResource AppSuccess}"
                                        FontSize="{StaticResource AppFontSize_XS}" />
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Style="{StaticResource AppStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Configuracion"
                            Style="{StaticResource AppCardLabelStyle}" />
                        <TextBox
                            Style="{StaticResource AppFieldTextBoxStyle}"
                            helpers:WatermarkService.Watermark="Nombre impresora"
                            Margin="0,8,0,8" />
                        <ComboBox
                            Style="{StaticResource AppFieldComboBoxStyle}"
                            SelectedIndex="0"
                            Margin="0,0,0,8">
                            <ComboBoxItem
                                Content="USB" />
                            <ComboBoxItem
                                Content="Ethernet" />
                        </ComboBox>
                        <TextBox
                            Style="{StaticResource AppFieldTextBoxStyle}"
                            helpers:WatermarkService.Watermark="IP"
                            Margin="0,0,0,8" />
                        <TextBox
                            Style="{StaticResource AppFieldTextBoxStyle}"
                            helpers:WatermarkService.Watermark="Puerto"
                            Margin="0,0,0,8" />
                        <ComboBox
                            Style="{StaticResource AppFieldComboBoxStyle}"
                            SelectedIndex="0"
                            Margin="0,0,0,18">
                            <ComboBoxItem
                                Content="80 mm" />
                            <ComboBoxItem
                                Content="58 mm" />
                        </ComboBox>
                        <Button
                            Style="{StaticResource AppSecondaryWideButtonStyle}"
                            Margin="0,0,0,10">
                            <TextBlock
                                Text="PRUEBA"
                                Foreground="{StaticResource AppBlanco}"
                                FontWeight="Bold" />
                        </Button>
                        <Button
                            Style="{StaticResource AppPrimaryWideButtonStyle}">
                            <TextBlock
                                Text="GUARDAR"
                                Foreground="{StaticResource AppBlanco}"
                                FontWeight="Bold" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
