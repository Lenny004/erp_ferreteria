<Window
    x:Class="Ferreteria.PuntoVenta.Views.Shell.MainShellWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ferreteria - Panel Operativo"
    Height="720"
    Width="1180"
    MinHeight="640"
    MinWidth="1024"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid
        Background="{StaticResource AppAzulOscuro}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="{StaticResource AppWidth_Sidebar}" />
            <ColumnDefinition
                Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="48" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="30" />
        </Grid.RowDefinitions>
        <Rectangle
            Grid.ColumnSpan="2"
            Height="3"
            VerticalAlignment="Top"
            Fill="{StaticResource AppRojo}"
            Opacity="0.8" />
        <Border
            Grid.Column="0"
            Grid.RowSpan="3"
            Background="{StaticResource AppAzulMedio}"
            BorderBrush="{StaticResource AppAzulClaro}"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition
                        Height="100" />
                    <RowDefinition
                        Height="*" />
                    <RowDefinition
                        Height="64" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                    <Image
                        Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/logo.png"
                        Width="48"
                        Height="48"
                        Stretch="Uniform" />
                    <TextBlock
                        Text="Ferreteria"
                        Foreground="{StaticResource AppBlanco}"
                        FontSize="{StaticResource AppFontSize_MD}"
                        FontWeight="{StaticResource AppFontWeight_Bold}"
                        HorizontalAlignment="Center"
                        Margin="0,6,0,0" />
                </StackPanel>
                <ScrollViewer
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock
                            x:Name="TxtNavSectionCaja"
                            Text="CAJA"
                            Style="{StaticResource AppNavSectionTitleStyle}" />
                        <Button
                            x:Name="BtnStock"
                            Style="{StaticResource AppNavButtonActiveStyle}"
                            Click="OnNavClick"
                            Tag="Stock">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/existence-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Consultar Stock"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnFacturacion"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Facturacion">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/bill.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Facturacion"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnHistorialFacturas"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="HistorialFacturas">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/historial_pedido-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Historial Facturas"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnImpresoras"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Impresoras">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/printer-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Impresoras"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnDevoluciones"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Devoluciones">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/return-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Devoluciones"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnCorteCaja"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="CorteCaja">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/cierre_caja-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Corte de caja"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Rectangle
                            x:Name="NavSectionDivider"
                            Style="{StaticResource AppNavDividerStyle}" />
                        <TextBlock
                            x:Name="TxtNavSectionInventario"
                            Text="INVENTARIO"
                            Style="{StaticResource AppNavSectionTitleStyle}" />
                        <Button
                            x:Name="BtnProductos"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Productos">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/existence-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Productos"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnProveedores"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Proveedores">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/confecciones.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Proveedores"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnMovimientos"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Movimientos">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/historial_pedido-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Entradas / Kardex"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnAlertas"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Alertas">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/return-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Alertas de Stock"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="BtnUsuarios"
                            Style="{StaticResource AppNavButtonStyle}"
                            Click="OnNavClick"
                            Tag="Usuarios">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="26" />
                                    <ColumnDefinition
                                        Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                    Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/codes-w.png"
                                    Width="20"
                                    Height="20" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Usuarios / RRHH"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
                <Button
                    Grid.Row="2"
                    Style="{StaticResource AppNavLogoutStyle}"
                    Click="OnLogoutClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="26" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image
                            Source="pack://application:,,,/Ferreteria.PuntoVenta;component/Resources/Images/exit-w.png"
                            Width="20"
                            Height="20" />
                        <TextBlock
                            Grid.Column="1"
                            Text="Cerrar sesion"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0" />
                    </Grid>
                </Button>
            </Grid>
        </Border>
        <Border
            Grid.Column="1"
            Grid.Row="0"
            Style="{StaticResource AppHeaderStyle}">
            <Grid>
                <TextBlock
                    x:Name="HeaderTitle"
                    Text="Consultar Stock"
                    Style="{StaticResource AppHeaderTitleStyle}" />
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                    <Button
                        Content="&#x2014;"
                        Style="{StaticResource AppWindowButtonStyle}"
                        Click="OnMinimizarClick" />
                    <Button
                        Content="&#x25A1;"
                        Style="{StaticResource AppWindowButtonStyle}"
                        Click="OnMaximizarClick" />
                    <Button
                        Content="&#x2715;"
                        Style="{StaticResource AppHeaderCloseHover}"
                        Click="OnCerrarClick" />
                </StackPanel>
            </Grid>
        </Border>
        <Border
            Grid.Column="1"
            Grid.Row="1"
            Padding="24">
            <ContentControl
                x:Name="MainContent" />
        </Border>
        <Border
            Grid.Column="1"
            Grid.Row="2"
            Style="{StaticResource AppStatusBarStyle}">
            <Grid>
                <TextBlock
                    x:Name="SessionText"
                    Text="Ferreteria 2026"
                    Style="{StaticResource AppStatusBarTextStyle}" />
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0">
                    <TextBlock
                        Text="Technical Support"
                        Foreground="{StaticResource AppGris}"
                        FontSize="{StaticResource AppFontSize_XS}"
                        Margin="0,0,16,0"
                        Cursor="Hand" />
                    <TextBlock
                        x:Name="ConnectivityText"
                        Text="Verificando conexion"
                        Foreground="{StaticResource AppGris}"
                        FontSize="{StaticResource AppFontSize_XS}"
                        Margin="0,0,16,0"
                        Cursor="Hand" />
                    <TextBlock
                        Text="Privacy Policy"
                        Foreground="{StaticResource AppGris}"
                        FontSize="{StaticResource AppFontSize_XS}"
                        Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
