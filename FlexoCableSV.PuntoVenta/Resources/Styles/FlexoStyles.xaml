<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

	<!-- ════════════════════════════════════════════
         PALETA OFICIAL FLEXOCABLE SV
    ════════════════════════════════════════════ -->

	<!-- Rojos corporativos -->
	<SolidColorBrush x:Key="FlexoRojo" Color="#cb2431"/>
	<SolidColorBrush x:Key="FlexoRojoDark" Color="#930019"/>
	<SolidColorBrush x:Key="FlexoRojoHover" Color="#E8293A"/>

	<!-- Neutros -->
	<SolidColorBrush x:Key="FlexoNegro" Color="#1E1E1E"/>
	<SolidColorBrush x:Key="FlexoBlanco" Color="#D4E4FA"/>
	<SolidColorBrush x:Key="FlexoGris" Color="#6E6D6D"/>
	<SolidColorBrush x:Key="FlexoGrisClaro" Color="#B0B0B0"/>
	<SolidColorBrush x:Key="FlexoGrisOscuro" Color="#3A3A3A"/>

	<!-- Estados -->
	<SolidColorBrush x:Key="FlexoSuccess" Color="#81C784"/>
	<SolidColorBrush x:Key="FlexoWarning" Color="#FFB74D"/>
	<SolidColorBrush x:Key="FlexoError" Color="#E57373"/>
	<SolidColorBrush x:Key="FlexoInfo" Color="#64B5F6"/>

	<!-- Azules de fondo -->
	<SolidColorBrush x:Key="FlexoAzulOscuro" Color="#051322"/>
	<SolidColorBrush x:Key="FlexoAzulMedio" Color="#1A1F2E"/>
	<SolidColorBrush x:Key="FlexoAzulClaro" Color="#1C2B3C"/>

	<!-- ════════════════════════════════════════════
         TIPOGRAFÍA FLEXOCABLE SV
    ════════════════════════════════════════════ -->

	<FontFamily x:Key="FlexoFontFamily">Segoe UI</FontFamily>

	<!-- Tamaños de fuente -->
	<sys:Double x:Key="FlexoFontSize_Display">30</sys:Double>
	<sys:Double x:Key="FlexoFontSize_XL">24</sys:Double>
	<sys:Double x:Key="FlexoFontSize_LG">16</sys:Double>
	<sys:Double x:Key="FlexoFontSize_MD">14</sys:Double>
	<sys:Double x:Key="FlexoFontSize_XS">11</sys:Double>

	<!-- Pesos de fuente -->
	<FontWeight x:Key="FlexoFontWeight_Light">Light</FontWeight>
	<FontWeight x:Key="FlexoFontWeight_Normal">Normal</FontWeight>
	<FontWeight x:Key="FlexoFontWeight_Medium">Medium</FontWeight>
	<FontWeight x:Key="FlexoFontWeight_Bold">Bold</FontWeight>

	<!-- ════════════════════════════════════════════
         ESPACIADOS FLEXOCABLE SV
    ════════════════════════════════════════════ -->

	<!-- Espaciados generales: mismo valor en los 4 lados -->
	<Thickness x:Key="FlexoSpacing_None">0</Thickness>
	<Thickness x:Key="FlexoSpacing_XXS">4</Thickness>
	<Thickness x:Key="FlexoSpacing_XS">8</Thickness>
	<Thickness x:Key="FlexoSpacing_SM">12</Thickness>
	<Thickness x:Key="FlexoSpacing_MD">16</Thickness>
	<Thickness x:Key="FlexoSpacing_LG">24</Thickness>
	<Thickness x:Key="FlexoSpacing_XL">32</Thickness>
	<Thickness x:Key="FlexoSpacing_XXL">40</Thickness>

	<!-- Espaciados horizontales: izquierda y derecha -->
	<Thickness x:Key="FlexoSpacing_XXS_Horizontal">4,0</Thickness>
	<Thickness x:Key="FlexoSpacing_XS_Horizontal">8,0</Thickness>
	<Thickness x:Key="FlexoSpacing_SM_Horizontal">12,0</Thickness>
	<Thickness x:Key="FlexoSpacing_MD_Horizontal">16,0</Thickness>
	<Thickness x:Key="FlexoSpacing_LG_Horizontal">24,0</Thickness>
	<Thickness x:Key="FlexoSpacing_XL_Horizontal">32,0</Thickness>
	<Thickness x:Key="FlexoSpacing_XXL_Horizontal">40,0</Thickness>

	<!-- Espaciados verticales: arriba y abajo -->
	<Thickness x:Key="FlexoSpacing_XXS_Vertical">0,4</Thickness>
	<Thickness x:Key="FlexoSpacing_XS_Vertical">0,8</Thickness>
	<Thickness x:Key="FlexoSpacing_SM_Vertical">0,12</Thickness>
	<Thickness x:Key="FlexoSpacing_MD_Vertical">0,16</Thickness>
	<Thickness x:Key="FlexoSpacing_LG_Vertical">0,24</Thickness>
	<Thickness x:Key="FlexoSpacing_XL_Vertical">0,32</Thickness>
	<Thickness x:Key="FlexoSpacing_XXL_Vertical">0,40</Thickness>

	<!-- Espaciados solo arriba -->
	<Thickness x:Key="FlexoSpacing_Top_XXS">0,4,0,0</Thickness>
	<Thickness x:Key="FlexoSpacing_Top_XS">0,8,0,0</Thickness>
	<Thickness x:Key="FlexoSpacing_Top_SM">0,12,0,0</Thickness>
	<Thickness x:Key="FlexoSpacing_Top_MD">0,16,0,0</Thickness>
	<Thickness x:Key="FlexoSpacing_Top_LG">0,24,0,0</Thickness>
	<Thickness x:Key="FlexoSpacing_Top_XL">0,32,0,0</Thickness>
	<Thickness x:Key="FlexoSpacing_Top_XXL">0,40,0,0</Thickness>

	<!-- Espaciados solo abajo -->
	<Thickness x:Key="FlexoSpacing_Bottom_XXS">0,0,0,4</Thickness>
	<Thickness x:Key="FlexoSpacing_Bottom_XS">0,0,0,8</Thickness>
	<Thickness x:Key="FlexoSpacing_Bottom_SM">0,0,0,12</Thickness>
	<Thickness x:Key="FlexoSpacing_Bottom_MD">0,0,0,16</Thickness>
	<Thickness x:Key="FlexoSpacing_Bottom_LG">0,0,0,24</Thickness>
	<Thickness x:Key="FlexoSpacing_Bottom_XL">0,0,0,32</Thickness>
	<Thickness x:Key="FlexoSpacing_Bottom_XXL">0,0,0,40</Thickness>

	<!-- Espaciados personalizados comunes -->
	<Thickness x:Key="FlexoPadding_Button">16,8</Thickness>
	<Thickness x:Key="FlexoPadding_ButtonLarge">24,12</Thickness>
	<Thickness x:Key="FlexoPadding_Card">16</Thickness>
	<Thickness x:Key="FlexoPadding_Window">24</Thickness>
	<Thickness x:Key="FlexoPadding_Input">12,8</Thickness>

	<Thickness x:Key="FlexoMargin_Section">0,0,0,24</Thickness>
	<Thickness x:Key="FlexoMargin_Card">0,0,0,16</Thickness>
	<Thickness x:Key="FlexoMargin_Title">0,0,0,12</Thickness>
	<Thickness x:Key="FlexoMargin_Subtitle">0,0,0,8</Thickness>

	<!-- ════════════════════════════════════════════
         TAMAÑOS NUMÉRICOS
    ════════════════════════════════════════════ -->

	<!-- Alturas -->
	<sys:Double x:Key="FlexoHeight_Button">36</sys:Double>
	<sys:Double x:Key="FlexoHeight_ButtonLarge">44</sys:Double>
	<sys:Double x:Key="FlexoHeight_Input">36</sys:Double>
	<sys:Double x:Key="FlexoHeight_Header">60</sys:Double>
	<sys:Double x:Key="FlexoHeight_Separator">4</sys:Double>

	<!-- Anchos -->
	<sys:Double x:Key="FlexoWidth_Button">120</sys:Double>
	<sys:Double x:Key="FlexoWidth_ButtonLarge">180</sys:Double>
	<sys:Double x:Key="FlexoWidth_Sidebar">240</sys:Double>
	<sys:Double x:Key="FlexoWidth_Icon">24</sys:Double>

	<!-- Bordes redondeados -->
	<sys:Double x:Key="FlexoRadius_XS">2</sys:Double>
	<sys:Double x:Key="FlexoRadius_SM">4</sys:Double>
	<sys:Double x:Key="FlexoRadius_MD">8</sys:Double>
	<sys:Double x:Key="FlexoRadius_LG">12</sys:Double>
	<sys:Double x:Key="FlexoRadius_XL">16</sys:Double>

	<!-- Grosor de bordes -->
	<sys:Double x:Key="FlexoBorderThickness_Thin">1</sys:Double>
	<sys:Double x:Key="FlexoBorderThickness_MD">2</sys:Double>
	<sys:Double x:Key="FlexoBorderThickness_LG">4</sys:Double>

	<!-- Opacidades -->
	<sys:Double x:Key="FlexoOpacity_Disabled">0.5</sys:Double>
	<sys:Double x:Key="FlexoOpacity_Hover">0.85</sys:Double>
	<sys:Double x:Key="FlexoOpacity_Pressed">0.7</sys:Double>

	<!-- ════════════════════════════════════════════
         BORDER THICKNESS
    ════════════════════════════════════════════ -->

	<Thickness x:Key="FlexoBorder_None">0</Thickness>
	<Thickness x:Key="FlexoBorder_Thin">1</Thickness>
	<Thickness x:Key="FlexoBorder_MD">2</Thickness>
	<Thickness x:Key="FlexoBorder_LG">4</Thickness>

	<!-- ════════════════════════════════════════════
         GRADIENTES
    ════════════════════════════════════════════ -->

	<LinearGradientBrush x:Key="FondoVentana" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Color="#051322" Offset="0"/>
		<GradientStop Color="#1A1F2E" Offset="0.5"/>
		<GradientStop Color="#1C2B3C" Offset="1"/>
	</LinearGradientBrush>

	<LinearGradientBrush x:Key="GradienteBoton" StartPoint="0,0" EndPoint="0,1">
		<GradientStop Color="#cb2431" Offset="0"/>
		<GradientStop Color="#930019" Offset="1"/>
	</LinearGradientBrush>

	<LinearGradientBrush x:Key="GradienteBotonHover" StartPoint="0,0" EndPoint="0,1">
		<GradientStop Color="#E8293A" Offset="0"/>
		<GradientStop Color="#B02030" Offset="1"/>
	</LinearGradientBrush>

	<Style x:Key="FlexoNavButtonStyle" TargetType="Button">
		<Setter Property="Height" Value="44"/>
		<Setter Property="Margin" Value="8,2"/>
		<Setter Property="Padding" Value="12,0"/>
		<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
		<Setter Property="Foreground" Value="{StaticResource FlexoBlanco}"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
		<Setter Property="FontSize" Value="{StaticResource FlexoFontSize_MD}"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Border x:Name="Root"
							Background="{TemplateBinding Background}"
							CornerRadius="4">
						<ContentPresenter VerticalAlignment="Center"/>
					</Border>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="Root"
									Property="Background"
									Value="{StaticResource FlexoAzulClaro}"/>
						</Trigger>
						<Trigger Property="IsPressed" Value="True">
							<Setter TargetName="Root"
									Property="Opacity"
									Value="{StaticResource FlexoOpacity_Pressed}"/>
						</Trigger>
						<Trigger Property="IsEnabled" Value="False">
							<Setter TargetName="Root"
									Property="Opacity"
									Value="{StaticResource FlexoOpacity_Disabled}"/>
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="FlexoWindowButtonStyle" TargetType="Button">
		<Setter Property="Width" Value="42"/>
		<Setter Property="Height" Value="32"/>
		<Setter Property="Foreground" Value="{StaticResource FlexoGrisClaro}"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
		<Setter Property="FontSize" Value="{StaticResource FlexoFontSize_MD}"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Border x:Name="Root"
							Background="{TemplateBinding Background}"
							CornerRadius="4">
						<ContentPresenter HorizontalAlignment="Center"
										  VerticalAlignment="Center"/>
					</Border>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="Root"
									Property="Background"
									Value="{StaticResource FlexoAzulClaro}"/>
						</Trigger>
						<Trigger Property="IsPressed" Value="True">
							<Setter TargetName="Root"
									Property="Opacity"
									Value="{StaticResource FlexoOpacity_Pressed}"/>
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
