<Window
    x:Class="FlexoCableSV.PuntoVenta.Views.PIN.PinWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FlexoCable SV - Iniciar Sesion"
    Height="560"
    Width="420"
    MinHeight="520"
    MinWidth="380"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/FlexoStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PinKeyStyle" TargetType="Button">
                <Setter Property="Width" Value="80" />
                <Setter Property="Height" Value="56" />
                <Setter Property="Margin" Value="6" />
                <Setter Property="Foreground" Value="{StaticResource FlexoBlanco}" />
                <Setter Property="Background" Value="{StaticResource FlexoAzulClaro}" />
                <Setter Property="BorderBrush" Value="{StaticResource FlexoAzulMedio}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}" />
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_XL}" />
                <Setter Property="FontWeight" Value="{StaticResource FlexoFontWeight_Normal}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FlexoRadius_MD}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{StaticResource FlexoGris}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Pressed}" />
                                    <Setter TargetName="Root" Property="Background" Value="{StaticResource FlexoGrisOscuro}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style
                x:Key="PinDeleteStyle"
                TargetType="Button"
                BasedOn="{StaticResource PinKeyStyle}">
                <Setter Property="Background" Value="{StaticResource FlexoGrisOscuro}" />
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_LG}" />
            </Style>

            <Style
                x:Key="PinConfirmStyle"
                TargetType="Button"
                BasedOn="{StaticResource PinKeyStyle}">
                <Setter Property="Background" Value="{StaticResource FlexoRojo}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="{StaticResource FlexoRadius_MD}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{StaticResource FlexoRojoHover}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Pressed}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource FondoVentana}" />

        <Rectangle
            Height="3"
            VerticalAlignment="Top"
            Fill="{StaticResource FlexoRojo}"
            Opacity="0.85" />

        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,0,8,0">
            <Button
                Content="&#x2014;"
                Style="{StaticResource FlexoWindowButtonStyle}"
                Click="OnMinimizarClick" />
            <Button
                Content="&#x2715;"
                Style="{StaticResource FlexoHeaderCloseHover}"
                Click="OnCerrarClick" />
        </StackPanel>

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="300">
            <TextBlock
                x:Name="PinTitleText"
                Text="INICIAR SESION"
                Style="{StaticResource FlexoPanelTitleStyle}"
                FontSize="{StaticResource FlexoFontSize_LG}"
                HorizontalAlignment="Center"
                Margin="0,0,0,4" />

            <TextBlock
                x:Name="PinSubtitleText"
                Text="Toque su PIN de 4 digitos"
                Style="{StaticResource FlexoPanelSubtitleStyle}"
                HorizontalAlignment="Center"
                Margin="0,0,0,24" />

            <Border
                Background="{StaticResource FlexoAzulOscuro}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="1"
                CornerRadius="{StaticResource FlexoRadius_MD}"
                Height="52"
                Margin="0,0,0,28">
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Ellipse
                        x:Name="Dot1"
                        Width="14"
                        Height="14"
                        Margin="10,0"
                        Fill="{StaticResource FlexoGris}" />
                    <Ellipse
                        x:Name="Dot2"
                        Width="14"
                        Height="14"
                        Margin="10,0"
                        Fill="{StaticResource FlexoGris}" />
                    <Ellipse
                        x:Name="Dot3"
                        Width="14"
                        Height="14"
                        Margin="10,0"
                        Fill="{StaticResource FlexoGris}" />
                    <Ellipse
                        x:Name="Dot4"
                        Width="14"
                        Height="14"
                        Margin="10,0"
                        Fill="{StaticResource FlexoGris}" />
                </StackPanel>
            </Border>

            <Grid HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="1" />
                <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="2" />
                <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="3" />

                <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="4" />
                <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="5" />
                <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="6" />

                <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="7" />
                <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="8" />
                <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="9" />

                <Button
                    Grid.Row="3"
                    Grid.Column="0"
                    Style="{StaticResource PinDeleteStyle}"
                    Click="OnBorrarClick"
                    ToolTip="Borrar ultimo digito">
                    <TextBlock
                        Text="&#x232B;"
                        FontSize="{StaticResource FlexoFontSize_LG}"
                        Foreground="{StaticResource FlexoBlanco}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Button>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource PinKeyStyle}" Click="OnDigitoClick" Tag="0" />
                <Button
                    Grid.Row="3"
                    Grid.Column="2"
                    Style="{StaticResource PinConfirmStyle}"
                    Click="OnConfirmarClick"
                    ToolTip="Confirmar PIN">
                    <TextBlock
                        Text="&#x2713;"
                        FontSize="{StaticResource FlexoFontSize_XL}"
                        FontWeight="{StaticResource FlexoFontWeight_Bold}"
                        Foreground="{StaticResource FlexoBlanco}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Button>
            </Grid>

            <Border
                x:Name="ErrorPanel"
                Background="{StaticResource FlexoRojoDark}"
                CornerRadius="{StaticResource FlexoRadius_SM}"
                Padding="12,8"
                Margin="0,20,0,0"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="ErrorMsg"
                    Text="PIN incorrecto. Intente de nuevo."
                    Foreground="{StaticResource FlexoBlanco}"
                    FontSize="{StaticResource FlexoFontSize_XS}"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource FlexoFontFamily}" />
            </Border>
        </StackPanel>

        <Border
            VerticalAlignment="Bottom"
            Style="{StaticResource FlexoStatusBarStyle}"
            Height="28">
            <TextBlock
                x:Name="StatusInfo"
                Text="FlexoCable SV - Modulo Ventas"
                Style="{StaticResource FlexoStatusBarTextStyle}" />
        </Border>
    </Grid>
</Window>
