nition Width="120"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="10:22" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="1" Text="DTE-03-000232" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="2" Text="Tarjeta" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="3" Text="$245.00" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="4" Text="OK" Style="{StaticResource FlexoTableCellStyle}" Foreground="{StaticResource FlexoSuccess}"/></Grid></Border></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource FlexoStatCardStyle}"><StackPanel><TextBlock Text="Conciliacion" Style="{StaticResource FlexoCardLabelStyle}"/><TextBlock Text="Cajero: Turno actual" Style="{StaticResource FlexoTableCellStyle}" Margin="0,12,0,4"/><TextBlock Text="Inicio: 08:00" Style="{StaticResource FlexoTableCellStyle}" Margin="0,0,0,12"/><TextBox Style="{StaticResource FlexoFieldTextBoxStyle}" Text="Efectivo contado" Foreground="{StaticResource FlexoGris}" Margin="0,0,0,8"/><TextBox Style="{StaticResource FlexoFieldTextBoxStyle}" Text="Observaciones" Foreground="{StaticResource FlexoGris}" Height="72" Margin="0,0,0,16"/><TextBlock Text="Diferencia: $0.00" Foreground="{StaticResource FlexoSuccess}" FontSize="{StaticResource FlexoFontSize_LG}" FontWeight="Bold" Margin="14,0,0,20"/><Button Style="{StaticResource FlexoSecondaryWideButtonStyle}" Margin="0,0,0,10"><TextBlock Text="CALCULAR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button><Button Style="{StaticResource FlexoPrimaryWideButtonStyle}"><TextBlock Text="CERRAR TURNO" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button></StackPanel></Border></Grid>
