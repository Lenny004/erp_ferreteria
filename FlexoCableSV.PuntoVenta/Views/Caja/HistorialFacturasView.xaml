        <Grid Grid.Row="2" Margin="0,0,0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/><ColumnDefinition Width="140"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource FlexoFieldTextBoxStyle}" Text="Buscar cliente, control, codigo generacion o NIT" Foreground="{StaticResource FlexoGris}"/><ComboBox Grid.Column="1" Style="{StaticResource FlexoFieldComboBoxStyle}" Margin="10,0,0,0" SelectedIndex="0"><ComboBoxItem Content="Hoy"/><ComboBoxItem Content="Semana"/><ComboBoxItem Content="Mes"/></ComboBox><ComboBox Grid.Column="2" Style="{StaticResource FlexoFieldComboBoxStyle}" Margin="10,0,0,0" SelectedIndex="0"><ComboBoxItem Content="Estado MH"/><ComboBoxItem Content="Procesado"/><ComboBoxItem Content="Pendiente"/></ComboBox><ComboBox Grid.Column="3" Style="{StaticResource FlexoFieldComboBoxStyle}" Margin="10,0,0,0" SelectedIndex="0"><ComboBoxItem Content="Tipo DTE"/><ComboBoxItem Content="01"/><ComboBoxItem Content="03"/></ComboBox></Grid>
        <Border Grid.Row="3" Background="{StaticResource FlexoAzulMedio}" BorderBrush="{StaticResource FlexoAzulClaro}" BorderThickness="1" CornerRadius="{StaticResource FlexoRadius_MD}"><Grid><Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid Style="{StaticResource FlexoGridHeaderStyle}"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="110"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><TextBlock Text="FECHA" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="1" Text="NO. CONTROL" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="2" Text="CLIENTE" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="3" Text="DTE" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="4" Text="PAGO" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="5" Text="TOTAL" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="6" Text="ESTADO" Style="{StaticResource FlexoGridHeaderTextStyle}"/></Grid><StackPanel Grid.Row="1"><Border Style="{StaticResource FlexoDataGridRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="110"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><TextBlock Text="12/06" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="1" Text="DTE-01-000231" Style="{StaticResource FlexoTableCellStyle}" Foreground="{StaticResource FlexoRojo}"/><TextBlock Grid.Column="2" Text="Juan Perez" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="3" Text="01" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="4" Text="Efectivo" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="5" Text="$86.45" Style="{StaticResource FlexoTableCellStyle}"/><Border Grid.Column="6" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}"><TextBlock Text="OK" Foreground="{StaticResource FlexoSuccess}" FontSize="{StaticResource FlexoFontSize_XS}"/></Border></Grid></Border><Border Style="{StaticResource FlexoDataGridRowStyle}" Background="{StaticResource FlexoAzulFilaAlt}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="110"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><TextBlock Text="12/06" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="1" Text="DTE-03-000232" Style="{StaticResource FlexoTableCellStyle}" Foreground="{StaticResource FlexoRojo}"/><TextBlock Grid.Column="2" Text="Transporte Central" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="3" Text="03" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="4" Text="Tarjeta" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="5" Text="$245.00" Style="{StaticResource FlexoTableCellStyle}"/><Border Grid.Column="6" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}"><TextBlock Text="PENDIENTE" Foreground="{StaticResource FlexoWarning}" FontSize="{StaticResource FlexoFontSize_XS}"/></Border></Grid></Border></StackPanel></Grid></Border>
    </Grid></ScrollViewer>
</UserControl>
