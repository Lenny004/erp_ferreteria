<UserControl
    x:Class="FlexoCableSV.PuntoVenta.Views.Caja.ConsultarStockView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:FlexoCableSV.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/FlexoStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="420" />
            </Grid.RowDefinitions>
            <Grid
                Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock
                        Text="Consultar Stock"
                        Style="{StaticResource FlexoPanelTitleStyle}" />
                    <TextBlock
                        Text="Vista rapida del inventario disponible y alertas de stock"
                        Style="{StaticResource FlexoPanelSubtitleStyle}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Style="{StaticResource FlexoSecondaryWideButtonStyle}"
                    Click="OnActualizarClick">
                    <TextBlock
                        Text="ACTUALIZAR"
                        Foreground="{StaticResource FlexoBlanco}"
                        FontWeight="Bold" />
                </Button>
            </Grid>
            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,0,0,16">
                <Border
                    Style="{StaticResource FlexoStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Productos activos"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="ActiveProductsText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource FlexoStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Stock bajo"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="StockLowText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}"
                            Foreground="{StaticResource FlexoWarning}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource FlexoStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Agotados"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="OutOfStockText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}"
                            Foreground="{StaticResource FlexoError}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource FlexoStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Actualizacion"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="LastUpdatedText"
                            Text="--:--"
                            Style="{StaticResource FlexoCardValueStyle}"
                            FontSize="{StaticResource FlexoFontSize_LG}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid
                Grid.Row="2"
                Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="140" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource FlexoFieldTextBoxStyle}"
                    helpers:WatermarkService.Watermark="Buscar codigo, descripcion o familia"
                    TextChanged="OnSearchChanged" />
                <ComboBox
                    x:Name="StatusFilterCombo"
                    Grid.Column="1"
                    Style="{StaticResource FlexoFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="0"
                    SelectionChanged="OnStatusFilterChanged">
                    <ComboBoxItem
                        Content="Todos"
                        Tag="TODOS" />
                    <ComboBoxItem
                        Content="OK"
                        Tag="OK" />
                    <ComboBoxItem
                        Content="Bajo"
                        Tag="BAJO" />
                    <ComboBoxItem
                        Content="Agotado"
                        Tag="AGOTADO" />
                </ComboBox>
            </Grid>
            <Border
                Grid.Row="3"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="1"
                CornerRadius="{StaticResource FlexoRadius_MD}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition
                            Height="40" />
                        <RowDefinition
                            Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Style="{StaticResource FlexoGridHeaderStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="130" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="CODIGO"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="DESCRIPCION"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="2"
                            Text="FAMILIA"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="3"
                            Text="MEDIDA"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="4"
                            Text="STOCK"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="5"
                            Text="ESTADO"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <TextBlock
                            x:Name="EmptyStateText"
                            Text="Sin productos para mostrar."
                            Style="{StaticResource FlexoTableCellStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ProductsItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource FlexoDataGridRowStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Text="{Binding Code}"
                                                    Style="{StaticResource FlexoTableCellStyle}"
                                                    Foreground="{StaticResource FlexoRojo}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding Description}"
                                                    Style="{StaticResource FlexoTableCellStyle}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Text="{Binding Family}"
                                                    Style="{StaticResource FlexoTableCellStyle}" />
                                                <TextBlock
                                                    Grid.Column="3"
                                                    Text="{Binding Measurement}"
                                                    Style="{StaticResource FlexoTableCellStyle}" />
                                                <TextBlock
                                                    Grid.Column="4"
                                                    Text="{Binding FormattedStock}"
                                                    Style="{StaticResource FlexoTableCellStyle}" />
                                                <Border
                                                    Grid.Column="5"
                                                    Style="{StaticResource FlexoBadgeStyle}"
                                                    Background="{StaticResource FlexoAzulClaro}">
                                                    <TextBlock
                                                        Text="{Binding Status}"
                                                        Foreground="{StaticResource FlexoBlanco}"
                                                        FontSize="{StaticResource FlexoFontSize_XS}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
