<UserControl x:Class="FlexoCableSV.PuntoVenta.Views.Caja.ImpresorasView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/Resources/Styles/FlexoStyles.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="470"/></Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,16"><TextBlock Text="Impresoras" Style="{StaticResource FlexoPanelTitleStyle}"/><TextBlock Text="Impresoras conectadas y configuracion de tickets" Style="{StaticResource FlexoPanelSubtitleStyle}"/></StackPanel>
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16"><Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Predeterminada" Style="{StaticResource FlexoCardLabelStyle}"/><TextBlock Text="EPSON TM-T20" Style="{StaticResource FlexoCardValueStyle}" FontSize="{StaticResource FlexoFontSize_LG}"/></StackPanel></Border><Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Ancho papel" Style="{StaticResource FlexoCardLabelStyle}"/><TextBlock Text="80 mm" Style="{StaticResource FlexoCardValueStyle}"/></StackPanel></Border><Border Style="{StaticResource FlexoStatCardStyle}"><StackPanel><TextBlock Text="Estado" Style="{StaticResource FlexoCardLabelStyle}"/><TextBlock Text="Lista" Style="{StaticResource FlexoCardValueStyle}" Foreground="{StaticResource FlexoSuccess}"/></StackPanel></Border></UniformGrid>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><Border Background="{StaticResource FlexoAzulMedio}" BorderBrush="{StaticResource FlexoAzulClaro}" BorderThickness="1" CornerRadius="{StaticResource FlexoRadius_MD}" Margin="0,0,12,0"><StackPanel><Grid Height="40" Style="{StaticResource FlexoGridHeaderStyle}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><TextBlock Text="NOMBRE" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="1" Text="CONEXION" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="2" Text="IP" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="3" Text="PAPEL" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="4" Text="ESTADO" Style="{StaticResource FlexoGridHeaderTextStyle}"/></Grid><Border Style="{StaticResource FlexoDataGridRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/><ColumnDefinition Width="100"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><TextBlock Text="EPSON TM-T20" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="1" Text="USB" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="2" Text="-" Style="{StaticResource FlexoTableCellStyle}"/><TextBlock Grid.Column="3" Text="80mm" Style="{StaticResource FlexoTableCellStyle}"/><Border Grid.Column="4" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}"><TextBlock Text="DEFAULT" Foreground="{StaticResource FlexoSuccess}" FontSize="{StaticResource FlexoFontSize_XS}"/></Border></Grid></Border></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource FlexoStatCardStyle}"><StackPanel><TextBlock Text="Configuracion" Style="{StaticResource FlexoCardLabelStyle}"/><TextBox Style="{StaticResource FlexoFieldTextBoxStyle}" Text="Nombre impresora" Foreground="{StaticResource FlexoGris}" Margin="0,8,0,8"/><ComboBox Style="{StaticResource FlexoFieldComboBoxStyle}" SelectedIndex="0" Margin="0,0,0,8"><ComboBoxItem Content="USB"/><ComboBoxItem Content="Ethernet"/></ComboBox><TextBox Style="{StaticResource FlexoFieldTextBoxStyle}" Text="IP" Foreground="{StaticResource FlexoGris}" Margin="0,0,0,8"/><TextBox Style="{StaticResource FlexoFieldTextBoxStyle}" Text="Puerto" Foreground="{StaticResource FlexoGris}" Margin="0,0,0,8"/><ComboBox Style="{StaticResource FlexoFieldComboBoxStyle}" SelectedIndex="0" Margin="0,0,0,18"><ComboBoxItem Content="80 mm"/><ComboBoxItem Content="58 mm"/></ComboBox><Button Style="{StaticResource FlexoSecondaryWideButtonStyle}" Margin="0,0,0,10"><TextBlock Text="PRUEBA" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button><Button Style="{StaticResource FlexoPrimaryWideButtonStyle}"><TextBlock Text="GUARDAR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button></StackPanel></Border></Grid>
    </Grid></ScrollViewer>
</UserControl>
