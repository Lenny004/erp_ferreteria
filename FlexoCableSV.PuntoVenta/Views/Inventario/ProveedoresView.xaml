<UserControl
    x:Class="FlexoCableSV.PuntoVenta.Views.Inventario.ProveedoresView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:FlexoCableSV.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/FlexoStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- Lista -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Proveedores" Style="{StaticResource FlexoPanelTitleStyle}" />
                <TextBlock Text="Gestione los proveedores de la ferreteria" Style="{StaticResource FlexoPanelSubtitleStyle}" />
            </StackPanel>
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource FlexoFieldTextBoxStyle}"
                    helpers:WatermarkService.Watermark="Buscar por nombre o NIT"
                    TextChanged="OnSearchChanged" />
                <Button
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Style="{StaticResource FlexoSecondaryWideButtonStyle}"
                    Click="OnNuevoClick">
                    <TextBlock Text="NUEVO" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold" />
                </Button>
            </Grid>
            <Border
                Grid.Row="2"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="1"
                CornerRadius="{StaticResource FlexoRadius_MD}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Style="{StaticResource FlexoGridHeaderStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="NOMBRE" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="1" Text="NIT" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock Grid.Column="2" Text="TELEFONO" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <TextBlock
                            x:Name="EmptyStateText"
                            Text="Sin proveedores para mostrar."
                            Style="{StaticResource FlexoTableCellStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ItemsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource FlexoDataGridRowStyle}"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="OnRowClick"
                                                Tag="{Binding Id}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="130" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource FlexoTableCellStyle}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Nit}" Style="{StaticResource FlexoTableCellStyle}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Phone}" Style="{StaticResource FlexoTableCellStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Formulario -->
        <Border
            Grid.Column="1"
            Background="{StaticResource FlexoAzulMedio}"
            BorderBrush="{StaticResource FlexoAzulClaro}"
            BorderThickness="1"
            CornerRadius="{StaticResource FlexoRadius_MD}"
            Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Nuevo proveedor" Style="{StaticResource FlexoPanelTitleStyle}" Margin="0,0,0,12" />

                    <TextBlock Text="Nombre / Razon social *" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="NameBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Nombre comercial" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="TradeNameBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="NIT" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="NitBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="NRC" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="NrcBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Contacto" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="ContactBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Telefono" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="PhoneBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Correo" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="EmailBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Direccion" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="AddressBox" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Dias de credito" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="CreditDaysBox" Text="0" Style="{StaticResource FlexoFieldTextBoxStyle}" Margin="0,4,0,10" />

                    <TextBlock Text="Notas" Style="{StaticResource FlexoCardLabelStyle}" />
                    <TextBox x:Name="NotesBox" Style="{StaticResource FlexoFieldTextBoxStyle}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,4,0,10" />

                    <TextBlock x:Name="FormErrorText" Foreground="{StaticResource FlexoError}"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,8" />

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource FlexoPrimaryWideButtonStyle}" Click="OnGuardarClick" Margin="0,0,6,0">
                            <TextBlock Text="GUARDAR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold" />
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource FlexoSecondaryWideButtonStyle}" Click="OnCancelarClick" Margin="6,0,0,0">
                            <TextBlock Text="LIMPIAR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold" />
                        </Button>
                    </Grid>
                    <Button x:Name="DeactivateButton" Style="{StaticResource FlexoSecondaryWideButtonStyle}"
                            Click="OnDesactivarClick" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock Text="DESACTIVAR" Foreground="{StaticResource FlexoError}" FontWeight="Bold" />
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
