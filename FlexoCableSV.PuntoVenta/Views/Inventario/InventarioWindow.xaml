<Window x:Class="FlexoCableSV.PuntoVenta.Views.Inventario.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlexoCable SV - Panel Operativo"
        Height="720" Width="1180"
        MinHeight="640" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/FlexoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FlexoActionButtonStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource FlexoRadius_SM}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Pressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Disabled}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionButtonSecondaryStyle" TargetType="Button" BasedOn="{StaticResource FlexoActionButtonSecondaryStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource FlexoRadius_SM}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Pressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Disabled}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionButtonPrimaryWideStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Width" Value="160"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="Background" Value="{StaticResource FlexoRojo}"/>
            </Style>

            <Style x:Key="ActionButtonWideStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonSecondaryStyle}">
                <Setter Property="Width" Value="150"/>
                <Setter Property="Height" Value="40"/>
            </Style>

            <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FlexoBlanco}"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_XL}"/>
                <Setter Property="FontWeight" Value="{StaticResource FlexoFontWeight_Bold}"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
            </Style>

            <Style x:Key="PanelSubtitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FlexoGrisClaro}"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_XS}"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
            </Style>

            <Style x:Key="CardLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FlexoGrisClaro}"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_XS}"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
            </Style>

            <Style x:Key="CardValueStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FlexoBlanco}"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_XL}"/>
                <Setter Property="FontWeight" Value="{StaticResource FlexoFontWeight_Bold}"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
            </Style>

            <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="12,7"/>
                <Setter Property="Background" Value="{StaticResource FlexoAzulOscuro}"/>
                <Setter Property="BorderBrush" Value="{StaticResource FlexoAzulClaro}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{StaticResource FlexoBlanco}"/>
                <Setter Property="CaretBrush" Value="{StaticResource FlexoBlanco}"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_MD}"/>
            </Style>

            <Style x:Key="FieldComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Background" Value="{StaticResource FlexoAzulOscuro}"/>
                <Setter Property="BorderBrush" Value="{StaticResource FlexoAzulClaro}"/>
                <Setter Property="Foreground" Value="{StaticResource FlexoNegro}"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_MD}"/>
            </Style>

            <Style x:Key="TableCellStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FlexoBlanco}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="14,0"/>
                <Setter Property="FontSize" Value="{StaticResource FlexoFontSize_XS}"/>
                <Setter Property="FontFamily" Value="{StaticResource FlexoFontFamily}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource FlexoAzulOscuro}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource FlexoWidth_Sidebar}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.ColumnSpan="2" Height="3" VerticalAlignment="Top" Fill="{StaticResource FlexoRojo}" Opacity="0.8"/>

        <Border Grid.Column="0"
                Grid.RowSpan="3"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="64"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/logo.png"
                           Width="48" Height="48" Stretch="Uniform"/>
                    <TextBlock Text="FlexoCable SV"
                               Foreground="{StaticResource FlexoBlanco}"
                               FontSize="{StaticResource FlexoFontSize_MD}"
                               FontWeight="{StaticResource FlexoFontWeight_Bold}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="CAJA" Style="{StaticResource FlexoNavSectionTitleStyle}"/>

                        <Button x:Name="BtnStock" Style="{StaticResource FlexoNavButtonActiveStyle}" Click="OnNavClick" Tag="Stock">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/existence-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Consultar Stock" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnFacturacion" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="Facturacion">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/bill.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Facturacion" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnHistorialFacturas" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="HistorialFacturas">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/historial_pedido-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Historial Facturas" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnImpresoras" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="Impresoras">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/printer-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Impresoras" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnDevoluciones" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="Devoluciones">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/return-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Devoluciones" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnCorteCaja" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="CorteCaja">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/cierre_caja-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Corte de caja" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>

                        <Rectangle Style="{StaticResource FlexoNavDividerStyle}"/>
                        <TextBlock Text="CONFECCION" Style="{StaticResource FlexoNavSectionTitleStyle}"/>

                        <Button x:Name="BtnHistorialVentas" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="HistorialVentas">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/comprobante-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Historial Ventas" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnOrdenes" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="Ordenes">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/confecciones.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Ordenes Confeccion" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                        <Button x:Name="BtnCodigos" Style="{StaticResource FlexoNavButtonStyle}" Click="OnNavClick" Tag="Codigos">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/codes-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Ver Codigos" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Style="{StaticResource FlexoNavLogoutStyle}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/exit-w.png" Width="20" Height="20"/><TextBlock Grid.Column="1" Text="Cerrar sesion" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource FlexoHeaderStyle}">
            <Grid>
                <TextBlock x:Name="HeaderTitle" Text="Consultar Stock" Style="{StaticResource FlexoHeaderTitleStyle}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Content="&#x2014;" Style="{StaticResource FlexoWindowButtonStyle}" Click="OnMinimizarClick"/>
                    <Button Content="&#x25A1;" Style="{StaticResource FlexoWindowButtonStyle}" Click="OnMaximizarClick"/>
                    <Button Content="&#x2715;" Style="{StaticResource FlexoHeaderCloseHover}" Click="OnCerrarClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Grid.Row="1" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid x:Name="PanelStock" Visibility="Visible">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="430"/></Grid.RowDefinitions>
                        <Grid Margin="0,0,0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Consultar Stock" Style="{StaticResource PanelTitleStyle}"/><TextBlock Text="Vista rapida del inventario disponible y alertas de stock" Style="{StaticResource PanelSubtitleStyle}"/></StackPanel><Button Grid.Column="1" Style="{StaticResource ActionButtonWideStyle}"><TextBlock Text="ACTUALIZAR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button></Grid>
                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                            <Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Productos activos" Style="{StaticResource CardLabelStyle}"/><TextBlock Text="524" Style="{StaticResource CardValueStyle}"/></StackPanel></Border>
                            <Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Stock bajo" Style="{StaticResource CardLabelStyle}"/><TextBlock Text="18" Style="{StaticResource CardValueStyle}" Foreground="{StaticResource FlexoWarning}"/></StackPanel></Border>
                            <Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Agotados" Style="{StaticResource CardLabelStyle}"/><TextBlock Text="7" Style="{StaticResource CardValueStyle}" Foreground="{StaticResource FlexoError}"/></StackPanel></Border>
                            <Border Style="{StaticResource FlexoStatCardStyle}"><StackPanel><TextBlock Text="Ultima actualizacion" Style="{StaticResource CardLabelStyle}"/><TextBlock Text="Ahora" Style="{StaticResource CardValueStyle}" FontSize="{StaticResource FlexoFontSize_LG}"/></StackPanel></Border>
                        </UniformGrid>
                        <Grid Grid.Row="2" Margin="0,0,0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="130"/><ColumnDefinition Width="130"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource FieldTextBoxStyle}" Text="Buscar codigo, descripcion o familia" Foreground="{StaticResource FlexoGris}"/><ComboBox Grid.Column="1" Style="{StaticResource FieldComboBoxStyle}" Margin="10,0,0,0" SelectedIndex="0"><ComboBoxItem Content="Todos"/><ComboBoxItem Content="OK"/><ComboBoxItem Content="Bajo"/><ComboBoxItem Content="Agotado"/></ComboBox><ComboBox Grid.Column="2" Style="{StaticResource FieldComboBoxStyle}" Margin="10,0,0,0" SelectedIndex="0"><ComboBoxItem Content="Familia"/><ComboBoxItem Content="Cables"/><ComboBoxItem Content="Boquillas"/><ComboBoxItem Content="Terminales"/></ComboBox><ComboBox Grid.Column="3" Style="{StaticResource FieldComboBoxStyle}" Margin="10,0,0,0" SelectedIndex="0"><ComboBoxItem Content="Medida"/><ComboBoxItem Content="METRO"/><ComboBoxItem Content="PIEZA"/><ComboBoxItem Content="KIT"/></ComboBox></Grid>
                        <Border Grid.Row="3" Background="{StaticResource FlexoAzulMedio}" BorderBrush="{StaticResource FlexoAzulClaro}" BorderThickness="1" CornerRadius="{StaticResource FlexoRadius_MD}"><Grid><Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid Style="{StaticResource FlexoGridHeaderStyle}"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="CODIGO" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="1" Text="DESCRIPCION" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="2" Text="FAMILIA" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="3" Text="MEDIDA" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="4" Text="STOCK" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="5" Text="MINIMO" Style="{StaticResource FlexoGridHeaderTextStyle}"/><TextBlock Grid.Column="6" Text="ESTADO" Style="{StaticResource FlexoGridHeaderTextStyle}"/></Grid><StackPanel Grid.Row="1"><Border Style="{StaticResource FlexoDataGridRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="01-CGA-03" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource FlexoRojo}"/><TextBlock Grid.Column="1" Text="Cable galvanizado acero #3" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="2" Text="Cables" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="3" Text="METRO" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="4" Text="128.50 m" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="5" Text="50.00 m" Style="{StaticResource TableCellStyle}"/><Border Grid.Column="6" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}"><TextBlock Text="OK" Foreground="{StaticResource FlexoSuccess}" FontSize="{StaticResource FlexoFontSize_XS}"/></Border></Grid></Border><Border Style="{StaticResource FlexoDataGridRowStyle}" Background="{StaticResource FlexoAzulFilaAlt}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="02-AC-01" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource FlexoRojo}"/><TextBlock Grid.Column="1" Text="Boquilla acelerador #1" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="2" Text="Boquillas" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="3" Text="PIEZA" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="4" Text="8 pz" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource FlexoWarning}"/><TextBlock Grid.Column="5" Text="15 pz" Style="{StaticResource TableCellStyle}"/><Border Grid.Column="6" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}"><TextBlock Text="BAJO" Foreground="{StaticResource FlexoWarning}" FontSize="{StaticResource FlexoFontSize_XS}"/></Border></Grid></Border><Border Style="{StaticResource FlexoDataGridRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="05-TR-07" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource FlexoRojo}"/><TextBlock Grid.Column="1" Text="Terminal reforzada 7mm" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="2" Text="Terminales" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="3" Text="PIEZA" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="4" Text="0 pz" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource FlexoError}"/><TextBlock Grid.Column="5" Text="20 pz" Style="{StaticResource TableCellStyle}"/><Border Grid.Column="6" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}"><TextBlock Text="AGOTADO" Foreground="{StaticResource FlexoError}" FontSize="{StaticResource FlexoFontSize_XS}"/></Border></Grid></Border></StackPanel></Grid></Border>
                    </Grid>

                    <Grid x:Name="PanelFacturacion" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="500"/></Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,16"><TextBlock Text="Facturacion" Style="{StaticResource PanelTitleStyle}"/><TextBlock Text="Crear orden, emitir DTE y preparar impresion de ticket" Style="{StaticResource PanelSubtitleStyle}"/></StackPanel>
                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16"><Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Tipo DTE" Style="{StaticResource CardLabelStyle}"/><ComboBox Style="{StaticResource FieldComboBoxStyle}" SelectedIndex="0" Margin="0,8,0,0"><ComboBoxItem Content="01 Consumidor Final"/><ComboBoxItem Content="03 Credito Fiscal"/></ComboBox></StackPanel></Border><Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Metodo de pago" Style="{StaticResource CardLabelStyle}"/><ComboBox Style="{StaticResource FieldComboBoxStyle}" SelectedIndex="0" Margin="0,8,0,0"><ComboBoxItem Content="Efectivo"/><ComboBoxItem Content="Tarjeta"/><ComboBoxItem Content="Transferencia"/></ComboBox></StackPanel></Border><Border Style="{StaticResource FlexoStatCardStyle}"><StackPanel><TextBlock Text="Total a facturar" Style="{StaticResource CardLabelStyle}"/><TextBlock Text="$ 86.45" Style="{StaticResource CardValueStyle}" Foreground="{StaticResource FlexoSuccess}"/></StackPanel></Border></UniformGrid>
                        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><Border Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Buscar producto" Style="{StaticResource CardLabelStyle}"/><TextBox Style="{StaticResource FieldTextBoxStyle}" Text="Codigo o descripcion" Foreground="{StaticResource FlexoGris}" Margin="0,8,0,12"/><Button Style="{StaticResource ActionButtonStyle}" Width="130"><TextBlock Text="AGREGAR" Foreground="{StaticResource FlexoAzulOscuro}" FontWeight="Bold"/></Button><Rectangle Height="1" Fill="{StaticResource FlexoAzulClaro}" Margin="0,16"/><TextBlock Text="Resultados" Style="{StaticResource CardLabelStyle}"/><TextBlock Text="01-CGA-03  Cable galvanizado" Style="{StaticResource TableCellStyle}" Margin="0,10,0,0"/><TextBlock Text="02-AC-01  Boquilla acelerador" Style="{StaticResource TableCellStyle}" Margin="0,8,0,0"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource FlexoStatCardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="Detalle de orden" Style="{StaticResource PanelSubtitleStyle}" Margin="0,0,0,10"/><StackPanel Grid.Row="1"><Border Style="{StaticResource FlexoDataGridRowStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/><ColumnDefinition Width="80"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions><TextBlock Text="Cable galvanizado acero #3" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="1" Text="5.50" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="2" Text="$12.50" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="3" Text="$68.75" Style="{StaticResource TableCellStyle}"/></Grid></Border><Border Style="{StaticResource FlexoDataGridRowStyle}" Background="{StaticResource FlexoAzulFilaAlt}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/><ColumnDefinition Width="80"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions><TextBlock Text="Boquilla acelerador #1" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="1" Text="2" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="2" Text="$7.10" Style="{StaticResource TableCellStyle}"/><TextBlock Grid.Column="3" Text="$14.20" Style="{StaticResource TableCellStyle}"/></Grid></Border></StackPanel></Grid></Border><Border Grid.Column="2" Style="{StaticResource FlexoStatCardStyle}"><StackPanel><TextBlock Text="Datos del cliente" Style="{StaticResource CardLabelStyle}"/><TextBox Style="{StaticResource FieldTextBoxStyle}" Text="Nombre cliente" Foreground="{StaticResource FlexoGris}" Margin="0,8,0,8"/><TextBox Style="{StaticResource FieldTextBoxStyle}" Text="NIT / NRC" Foreground="{StaticResource FlexoGris}" Margin="0,0,0,16"/><TextBlock Text="Subtotal: $76.50" Style="{StaticResource TableCellStyle}" Margin="0,0,0,6"/><TextBlock Text="IVA: $9.95" Style="{StaticResource TableCellStyle}" Margin="0,0,0,6"/><TextBlock Text="Total: $86.45" Foreground="{StaticResource FlexoSuccess}" FontSize="{StaticResource FlexoFontSize_XL}" FontWeight="Bold" Margin="14,6,0,20"/><Button Style="{StaticResource ActionButtonPrimaryWideStyle}"><TextBlock Text="FACTURAR DTE" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button><Button Style="{StaticResource ActionButtonWideStyle}" Margin="0,10,0,0"><TextBlock Text="GUARDAR BORRADOR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold"/></Button></StackPanel></Border></Grid>
                    </Grid>

                    <Grid x:Name="PanelHistorialFacturas" Visibility="Collapsed">
