<Window x:Class="FlexoCableSV.PuntoVenta.Views.Inventario.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FlexoCable SV - Inventario"
        Height="600" Width="900"
        MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/FlexoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FlexoActionButtonStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource FlexoRadius_SM}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Pressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Disabled}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionButtonSecondaryStyle" TargetType="Button" BasedOn="{StaticResource FlexoActionButtonSecondaryStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource FlexoRadius_SM}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Pressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="{StaticResource FlexoOpacity_Disabled}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource FlexoAzulOscuro}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource FlexoWidth_Sidebar}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ─── BARRA ROJA SUPERIOR ─── -->
        <Rectangle Grid.ColumnSpan="2"
                   Height="3"
                   VerticalAlignment="Top"
                   Fill="{StaticResource FlexoRojo}"
                   Opacity="0.8"/>

        <!-- ═══════════════════════════════════════
             SIDENAV (COLUMNA 0) — ANCHO REDUCIDO A 200px
        ═══════════════════════════════════════ -->
        <Border Grid.Column="0"
                Grid.RowSpan="3"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Logo: altura reducida -->
                    <RowDefinition Height="100"/>
                    <!-- Navegación (con scroll) -->
                    <RowDefinition Height="*"/>
                    <!-- Cerrar sesión -->
                    <RowDefinition Height="64"/>
                </Grid.RowDefinitions>

                <!-- ── LOGO — TAMAÑO REDUCIDO ── -->
                <StackPanel Grid.Row="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/logo.png"
                           Width="48" Height="48"
                           Stretch="Uniform"/>
                    <TextBlock Text="FlexoCable SV"
                               Foreground="{StaticResource FlexoBlanco}"
                               FontSize="{StaticResource FlexoFontSize_MD}"
                               FontWeight="{StaticResource FlexoFontWeight_Bold}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- ── BOTONES DE NAVEGACIÓN ── -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,4,0,0">
                    <StackPanel>

                        <!-- ══════════════════════ SECCIÓN CAJA ══════════════════════ -->
                        <TextBlock Text="CAJA"
                                   Style="{StaticResource FlexoNavSectionTitleStyle}"/>

                        <!-- CONSULTAR STOCK -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/existence-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Consultar Stock"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- FACTURACIÓN -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/bill.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Facturación"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- HISTORIAL DE FACTURAS -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/historial_pedido-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Historial Facturas"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- IMPRESORAS -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/printer-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Impresoras"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- DEVOLUCIONES -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/return-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Devoluciones"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                        <!-- CORTE DE CAJA -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/cierre_caja-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Corte de caja"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <Rectangle Style="{StaticResource FlexoNavDividerStyle}"/>

                        <!-- ══════════════════════ SECCIÓN CONFECCIÓN ══════════════════════ -->
                        <TextBlock Text="CONFECCION"
                                   Style="{StaticResource FlexoNavSectionTitleStyle}"/>

                        <!-- HISTORIAL VENTAS -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/comprobante-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Historial Ventas"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- ÓRDENES CONFECCIÓN -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/confecciones.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Órdenes Confección"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- VER CÓDIGOS -->
                        <Button Style="{StaticResource FlexoNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/codes-w.png"
                                       Width="20" Height="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="Ver Códigos"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── CERRAR SESIÓN ── -->
                <Button Grid.Row="2"
                        Style="{StaticResource FlexoNavLogoutStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/exit-w.png"
                               Width="20" Height="20"/>
                        <TextBlock Grid.Column="1"
                                   Text="Cerrar sesion"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             HEADER (COLUMNA 1, FILA 0)
        ═══════════════════════════════════════ -->
        <Border Grid.Column="1"
                Grid.Row="0"
                Style="{StaticResource FlexoHeaderStyle}">
            <Grid>
                <TextBlock Text="Inventario"
                           Style="{StaticResource FlexoHeaderTitleStyle}"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Content="&#x2014;"
                            Style="{StaticResource FlexoWindowButtonStyle}"
                            Click="OnMinimizarClick"/>
                    <Button Content="&#x25A1;"
                            Style="{StaticResource FlexoWindowButtonStyle}"
                            Click="OnMaximizarClick"/>
                    <Button Content="&#x2715;"
                            Style="{StaticResource FlexoHeaderCloseHover}"
                            Click="OnCerrarClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             CONTENIDO PRINCIPAL (COLUMNA 1, FILA 1)
             REESTRUCTURADO: Tabs → Buscador → Tabla → Stats
        ═══════════════════════════════════════ -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Título + botones -->
                    <RowDefinition Height="Auto"/>
                    <!-- Tabs -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buscador -->
                    <RowDefinition Height="Auto"/>
                    <!-- Tabla -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── FILA 0: TITULO + BOTONES ACCION ── -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Inventario"
                                   Foreground="{StaticResource FlexoBlanco}"
                                   FontSize="{StaticResource FlexoFontSize_XL}"
                                   FontWeight="{StaticResource FlexoFontWeight_Bold}"/>
                        <TextBlock Text="Vista visual del modulo de stock y movimientos"
                                   Foreground="{StaticResource FlexoGrisClaro}"
                                   FontSize="{StaticResource FlexoFontSize_XS}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource ActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/Resources/Images/add-blue.png"
                                       Width="16" Height="16"/>
                                <TextBlock Text="AGREGAR"
                                           Foreground="{StaticResource FlexoAzulOscuro}" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ── FILA 2: BUSCADOR + FILTROS ── -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource FlexoAzulOscuro}"
                            BorderBrush="{StaticResource FlexoAzulClaro}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FlexoRadius_SM}"
                            Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/search.png"
                                   Width="20" Height="20"
                                   Opacity="0.7"/>
                            <TextBlock Grid.Column="1"
                                       Text="Buscar codigo o descripcion"
                                       Foreground="{StaticResource FlexoGris}"
                                       FontSize="{StaticResource FlexoFontSize_MD}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2"
                            Style="{StaticResource ActionButtonSecondaryStyle}" Margin="30,0,6,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Source="pack://application:,,,/FlexoCableSV.PuntoVenta;component/Resources/Images/search.png"
                                   Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="FILTROS" VerticalAlignment="Center" FontWeight="Bold"
                                       Foreground="{StaticResource FlexoBlanco}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ── FILA 3: TABLA DE DATOS ── -->
                <Border Grid.Row="3"
                        Background="{StaticResource FlexoAzulMedio}"
                        BorderBrush="{StaticResource FlexoAzulClaro}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource FlexoRadius_MD}"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Headers de tabla -->
                        <Grid Grid.Row="0"
                              Style="{StaticResource FlexoGridHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CODIGO" Style="{StaticResource FlexoGridHeaderTextStyle}"/>
                            <TextBlock Grid.Column="1" Text="DESCRIPCION" Style="{StaticResource FlexoGridHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="TIPO" Style="{StaticResource FlexoGridHeaderTextStyle}"/>
                            <TextBlock Grid.Column="3" Text="STOCK ACTUAL" Style="{StaticResource FlexoGridHeaderTextStyle}"/>
                            <TextBlock Grid.Column="4" Text="STOCK MINIMO" Style="{StaticResource FlexoGridHeaderTextStyle}"/>
                            <TextBlock Grid.Column="5" Text="ESTADO" Style="{StaticResource FlexoGridHeaderTextStyle}"/>
                        </Grid>

                        <!-- Filas con alternancia de color -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Fila 1: fondo normal -->
                                <Border Style="{StaticResource FlexoDataGridRowStyle}"
                                        Background="{StaticResource FlexoAzulMedio}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CBL-THW-12AWG-BK"
                                                   Foreground="{StaticResource FlexoRojo}"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"
                                                   FontWeight="{StaticResource FlexoFontWeight_Medium}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Cable THW 12 AWG Negro Industrial"
                                                   Foreground="{StaticResource FlexoBlanco}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="Conductor"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="1,258 m"
                                                   Foreground="{StaticResource FlexoBlanco}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="500 m"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <Grid Grid.Column="5" VerticalAlignment="Center" Margin="14,0">
                                            <Border Style="{StaticResource FlexoBadgeStyle}"
                                                    Background="#1B4D2E">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="{StaticResource FlexoSuccess}"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="OK"
                                                               Foreground="{StaticResource FlexoSuccess}"
                                                               FontSize="{StaticResource FlexoFontSize_XS}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Fila 2: fondo alterno -->
                                <Border Style="{StaticResource FlexoDataGridRowStyle}"
                                        Background="{StaticResource FlexoAzulFilaAlt}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CBL-SOOW-10/3"
                                                   Foreground="{StaticResource FlexoRojo}"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"
                                                   FontWeight="{StaticResource FlexoFontWeight_Medium}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Cable SOOW 10/3 Uso Rudo 600V"
                                                   Foreground="{StaticResource FlexoBlanco}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="Conductor"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="185 m"
                                                   Foreground="{StaticResource FlexoWarning}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="250 m"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <Grid Grid.Column="5" VerticalAlignment="Center" Margin="14,0">
                                            <Border Style="{StaticResource FlexoBadgeStyle}"
                                                    Background="#4D2E1B">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="{StaticResource FlexoWarning}"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="BAJO"
                                                               Foreground="{StaticResource FlexoWarning}"
                                                               FontSize="{StaticResource FlexoFontSize_XS}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Fila 3: fondo normal -->
                                <Border Style="{StaticResource FlexoDataGridRowStyle}"
                                        Background="{StaticResource FlexoAzulMedio}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CON-EMT-3/4"
                                                   Foreground="{StaticResource FlexoRojo}"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"
                                                   FontWeight="{StaticResource FlexoFontWeight_Medium}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Conector EMT 3/4 Zinc Presion"
                                                   Foreground="{StaticResource FlexoBlanco}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="Ferreteria"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="8 pz"
                                                   Foreground="{StaticResource FlexoError}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="100 pz"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <Grid Grid.Column="5" VerticalAlignment="Center" Margin="14,0">
                                            <Border Style="{StaticResource FlexoBadgeStyle}"
                                                    Background="#4D1B1B">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="{StaticResource FlexoError}"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="AGOTADO"
                                                               Foreground="{StaticResource FlexoError}"
                                                               FontSize="{StaticResource FlexoFontSize_XS}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Fila 4: fondo alterno -->
                                <Border Style="{StaticResource FlexoDataGridRowStyle}"
                                        Background="{StaticResource FlexoAzulFilaAlt}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CBL-RG6-QUAD-WH"
                                                   Foreground="{StaticResource FlexoRojo}"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"
                                                   FontWeight="{StaticResource FlexoFontWeight_Medium}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Coaxial RG6 Quad Shield Blanco"
                                                   Foreground="{StaticResource FlexoBlanco}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="Telecom"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="3,800 m"
                                                   Foreground="{StaticResource FlexoBlanco}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="1,000 m"
                                                   Foreground="{StaticResource FlexoGrisClaro}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FlexoFontSize_XS}"/>
                                        <Grid Grid.Column="5" VerticalAlignment="Center" Margin="14,0">
                                            <Border Style="{StaticResource FlexoBadgeStyle}"
                                                    Background="#1B4D2E">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="{StaticResource FlexoSuccess}"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="OK"
                                                               Foreground="{StaticResource FlexoSuccess}"
                                                               FontSize="{StaticResource FlexoFontSize_XS}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             STATUSBAR (COLUMNA 1, FILA 2)
        ═══════════════════════════════════════ -->
        <Border Grid.Column="1"
                Grid.Row="2"
                Style="{StaticResource FlexoStatusBarStyle}">
            <Grid>
                <TextBlock Text="FlexoCable El Salvador 2026"
                           Style="{StaticResource FlexoStatusBarTextStyle}"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <TextBlock Text="Technical Support"
                               Foreground="{StaticResource FlexoGris}"
                               FontSize="{StaticResource FlexoFontSize_XS}"
                               Margin="0,0,16,0"
                               Cursor="Hand"/>
                    <TextBlock Text="System Status"
                               Foreground="{StaticResource FlexoGris}"
                               FontSize="{StaticResource FlexoFontSize_XS}"
                               Margin="0,0,16,0"
                               Cursor="Hand"/>
                    <TextBlock Text="Privacy Policy"
                               Foreground="{StaticResource FlexoGris}"
                               FontSize="{StaticResource FlexoFontSize_XS}"
                               Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
