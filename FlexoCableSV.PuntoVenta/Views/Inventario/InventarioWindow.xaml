<Window x:Class="FlexoCableSV.PuntoVenta.Views.Inventario.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FlexoCable SV - Inventario"
        Height="560" Width="760"
        MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/FlexoStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource FlexoAzulOscuro}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource FlexoWidth_Sidebar}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.ColumnSpan="2"
                   Height="3"
                   VerticalAlignment="Top"
                   Fill="{StaticResource FlexoRojo}"
                   Opacity="0.8"/>

        <Border Grid.Column="0"
                Grid.RowSpan="3"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="64"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Image Source="/Resources/Images/logo.png"
                           Width="64"
                           Height="64"
                           Stretch="Uniform"/>
                    <TextBlock Text="FlexoCable SV"
                               Foreground="{StaticResource FlexoBlanco}"
                               FontSize="{StaticResource FlexoFontSize_MD}"
                               FontWeight="{StaticResource FlexoFontWeight_Bold}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="Punto de venta"
                               Foreground="{StaticResource FlexoGris}"
                               FontSize="{StaticResource FlexoFontSize_XS}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="CAJA"
                               Foreground="{StaticResource FlexoGris}"
                               FontSize="{StaticResource FlexoFontSize_XS}"
                               FontWeight="{StaticResource FlexoFontWeight_Bold}"
                               Margin="20,8,0,6"/>

                    <Button Style="{StaticResource FlexoNavButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Resources/Images/register-w.png" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="Ventas" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource FlexoNavButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Resources/Images/add-w.png" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="Nueva orden" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource FlexoNavButtonStyle}"
                            Background="{StaticResource FlexoAzulClaro}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Resources/Images/boxes.png" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="Inventario" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource FlexoNavButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Resources/Images/bill.png" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="Facturacion" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <TextBlock Text="CONFECCION"
                               Foreground="{StaticResource FlexoGris}"
                               FontSize="{StaticResource FlexoFontSize_XS}"
                               FontWeight="{StaticResource FlexoFontWeight_Bold}"
                               Margin="20,18,0,6"/>

                    <Button Style="{StaticResource FlexoNavButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Resources/Images/rule-w.png" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="Codigos" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource FlexoNavButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Resources/Images/printer-w.png" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="Impresoras" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <Button Grid.Row="2"
                        Style="{StaticResource FlexoNavButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="/Resources/Images/exit-w.png" Width="20" Height="20"/>
                        <TextBlock Grid.Column="1" Text="Cerrar sesion" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="Inventario"
                           Foreground="{StaticResource FlexoBlanco}"
                           FontSize="{StaticResource FlexoFontSize_MD}"
                           FontWeight="{StaticResource FlexoFontWeight_Medium}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Content="-"
                            Style="{StaticResource FlexoWindowButtonStyle}"/>
                    <Button Content="[]"
                            Style="{StaticResource FlexoWindowButtonStyle}"/>
                    <Button Content="X"
                            Style="{StaticResource FlexoWindowButtonStyle}"
                            Foreground="{StaticResource FlexoRojo}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="1"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Inventario"
                                   Foreground="{StaticResource FlexoBlanco}"
                                   FontSize="{StaticResource FlexoFontSize_XL}"
                                   FontWeight="{StaticResource FlexoFontWeight_Bold}"/>
                        <TextBlock Text="Vista visual del modulo de stock y movimientos"
                                   Foreground="{StaticResource FlexoGrisClaro}"
                                   FontSize="{StaticResource FlexoFontSize_XS}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource FlexoNavButtonStyle}"
                                Width="112"
                                Margin="4,0"
                                Background="{StaticResource GradienteBoton}">
                            <TextBlock Text="Entrada"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource FlexoNavButtonStyle}"
                                Width="112"
                                Margin="4,0">
                            <TextBlock Text="Ajuste"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,22,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource FlexoAzulMedio}"
                            BorderBrush="{StaticResource FlexoAzulClaro}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Productos"
                                       Foreground="{StaticResource FlexoGrisClaro}"
                                       FontSize="{StaticResource FlexoFontSize_XS}"/>
                            <TextBlock Text="528"
                                       Foreground="{StaticResource FlexoBlanco}"
                                       FontSize="{StaticResource FlexoFontSize_XL}"
                                       FontWeight="{StaticResource FlexoFontWeight_Bold}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource FlexoAzulMedio}"
                            BorderBrush="{StaticResource FlexoAzulClaro}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Stock bajo"
                                       Foreground="{StaticResource FlexoGrisClaro}"
                                       FontSize="{StaticResource FlexoFontSize_XS}"/>
                            <TextBlock Text="18"
                                       Foreground="{StaticResource FlexoWarning}"
                                       FontSize="{StaticResource FlexoFontSize_XL}"
                                       FontWeight="{StaticResource FlexoFontWeight_Bold}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Background="{StaticResource FlexoAzulMedio}"
                            BorderBrush="{StaticResource FlexoAzulClaro}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Movimientos"
                                       Foreground="{StaticResource FlexoGrisClaro}"
                                       FontSize="{StaticResource FlexoFontSize_XS}"/>
                            <TextBlock Text="42"
                                       Foreground="{StaticResource FlexoInfo}"
                                       FontSize="{StaticResource FlexoFontSize_XL}"
                                       FontWeight="{StaticResource FlexoFontWeight_Bold}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="{StaticResource FlexoAzulMedio}"
                        BorderBrush="{StaticResource FlexoAzulClaro}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="{StaticResource FlexoAzulOscuro}"
                                    BorderBrush="{StaticResource FlexoAzulClaro}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/Resources/Images/search.png"
                                           Width="18"
                                           Height="18"
                                           Opacity="0.7"/>
                                    <TextBlock Grid.Column="1"
                                               Text="Buscar codigo o descripcion"
                                               Foreground="{StaticResource FlexoGris}"
                                               FontSize="{StaticResource FlexoFontSize_MD}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Style="{StaticResource FlexoNavButtonStyle}"
                                    Margin="0"
                                    Background="{StaticResource FlexoAzulClaro}">
                                <TextBlock Text="Filtros"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1"
                              Background="{StaticResource FlexoAzulClaro}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Codigo" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center" Margin="14,0"/>
                            <TextBlock Grid.Column="1" Text="Producto" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Stock" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Minimo" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Estado" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="02-AC-01" Foreground="{StaticResource FlexoGrisClaro}" VerticalAlignment="Center" Margin="14,0"/>
                                <TextBlock Grid.Column="1" Text="Cable acero inoxidable" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="148.50" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="25.00" Foreground="{StaticResource FlexoGrisClaro}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Disponible" Foreground="{StaticResource FlexoSuccess}" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource FlexoAzulClaro}"/>

                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="04-TR-12" Foreground="{StaticResource FlexoGrisClaro}" VerticalAlignment="Center" Margin="14,0"/>
                                <TextBlock Grid.Column="1" Text="Terminal reforzado" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="14" Foreground="{StaticResource FlexoWarning}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="20" Foreground="{StaticResource FlexoGrisClaro}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Stock bajo" Foreground="{StaticResource FlexoWarning}" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource FlexoAzulClaro}"/>

                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="07-KT-03" Foreground="{StaticResource FlexoGrisClaro}" VerticalAlignment="Center" Margin="14,0"/>
                                <TextBlock Grid.Column="1" Text="Kit reparacion cable" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="36" Foreground="{StaticResource FlexoBlanco}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="10" Foreground="{StaticResource FlexoGrisClaro}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Disponible" Foreground="{StaticResource FlexoSuccess}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="2"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="FlexoCable El Salvador 2026"
                       Foreground="{StaticResource FlexoBlanco}"
                       FontSize="{StaticResource FlexoFontSize_XS}"
                       FontWeight="{StaticResource FlexoFontWeight_Light}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </Border>
    </Grid>
</Window>
