<UserControl
    x:Class="FlexoCableSV.PuntoVenta.Views.Inventario.AlertasView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/FlexoStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Alertas de Stock" Style="{StaticResource FlexoPanelTitleStyle}" />
                <TextBlock Text="Productos en o por debajo del stock minimo" Style="{StaticResource FlexoPanelSubtitleStyle}" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource FlexoSecondaryWideButtonStyle}" Click="OnActualizarClick">
                <TextBlock Text="ACTUALIZAR" Foreground="{StaticResource FlexoBlanco}" FontWeight="Bold" />
            </Button>
        </Grid>
        <Border
            Grid.Row="1"
            Background="{StaticResource FlexoAzulMedio}"
            BorderBrush="{StaticResource FlexoAzulClaro}"
            BorderThickness="1"
            CornerRadius="{StaticResource FlexoRadius_MD}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Style="{StaticResource FlexoGridHeaderStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CODIGO" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    <TextBlock Grid.Column="1" Text="PRODUCTO" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    <TextBlock Grid.Column="2" Text="STOCK" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    <TextBlock Grid.Column="3" Text="MINIMO" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    <TextBlock Grid.Column="4" Text="ESTADO" Style="{StaticResource FlexoGridHeaderTextStyle}" />
                </Grid>
                <Grid Grid.Row="1">
                    <TextBlock
                        x:Name="EmptyStateText"
                        Text="No hay alertas de stock activas."
                        Style="{StaticResource FlexoTableCellStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ItemsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource FlexoDataGridRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ProductCode}" Style="{StaticResource FlexoTableCellStyle}" Foreground="{StaticResource FlexoRojo}" />
                                            <TextBlock Grid.Column="1" Text="{Binding ProductDescription}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <TextBlock Grid.Column="2" Text="{Binding CurrentStock}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <TextBlock Grid.Column="3" Text="{Binding MinStock}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <Border Grid.Column="4" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoWarning}">
                                                <TextBlock Text="{Binding AlertType}" Foreground="{StaticResource FlexoNegro}" FontSize="{StaticResource FlexoFontSize_XS}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
