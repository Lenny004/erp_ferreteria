<UserControl
    x:Class="FlexoCableSV.PuntoVenta.Views.Confeccion.HistorialVentasView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:FlexoCableSV.PuntoVenta.Helpers">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Styles/FlexoStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="420" />
            </Grid.RowDefinitions>
            <StackPanel
                Margin="0,0,0,16">
                <TextBlock
                    Text="Historial de Ventas"
                    Style="{StaticResource FlexoPanelTitleStyle}" />
                <TextBlock
                    Text="Ordenes de confeccion registradas y estados de produccion"
                    Style="{StaticResource FlexoPanelSubtitleStyle}" />
            </StackPanel>
            <UniformGrid
                Grid.Row="1"
                Columns="4"
                Margin="0,0,0,16">
                <Border
                    Style="{StaticResource FlexoStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Ordenes hoy"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="OrdersTodayText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource FlexoStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="Pendientes"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="PendingText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}"
                            Foreground="{StaticResource FlexoWarning}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource FlexoStatCardStyle}"
                    Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock
                            Text="En proceso"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="ShownText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}"
                            Foreground="{StaticResource FlexoInfo}" />
                    </StackPanel>
                </Border>
                <Border
                    Style="{StaticResource FlexoStatCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Text="Finalizadas"
                            Style="{StaticResource FlexoCardLabelStyle}" />
                        <TextBlock
                            x:Name="CompletedText"
                            Text="0"
                            Style="{StaticResource FlexoCardValueStyle}"
                            Foreground="{StaticResource FlexoSuccess}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid
                Grid.Row="2"
                Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="140" />
                    <ColumnDefinition
                        Width="140" />
                    <ColumnDefinition
                        Width="140" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource FlexoFieldTextBoxStyle}"
                    helpers:WatermarkService.Watermark="Buscar cliente, tecnico u orden"
                    TextChanged="OnSearchChanged" />
                <ComboBox
                    Grid.Column="1"
                    Style="{StaticResource FlexoFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="0">
                    <ComboBoxItem
                        Content="Fecha" />
                    <ComboBoxItem
                        Content="Hoy" />
                    <ComboBoxItem
                        Content="Semana" />
                </ComboBox>
                <ComboBox
                    Grid.Column="2"
                    Style="{StaticResource FlexoFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="0">
                    <ComboBoxItem
                        Content="Tecnico" />
                    <ComboBoxItem
                        Content="Todos" />
                </ComboBox>
                <ComboBox
                    x:Name="StatusFilterCombo"
                    Grid.Column="3"
                    Style="{StaticResource FlexoFieldComboBoxStyle}"
                    Margin="10,0,0,0"
                    SelectedIndex="1"
                    SelectionChanged="OnStatusFilterChanged">
                    <ComboBoxItem
                        Content="Todos"
                        Tag="TODOS" />
                    <ComboBoxItem
                        Content="Pendiente"
                        Tag="PENDIENTE" />
                    <ComboBoxItem
                        Content="Completada"
                        Tag="COMPLETADA" />
                    <ComboBoxItem
                        Content="Cancelada"
                        Tag="CANCELADA" />
                </ComboBox>
            </Grid>
            <Border
                Grid.Row="3"
                Background="{StaticResource FlexoAzulMedio}"
                BorderBrush="{StaticResource FlexoAzulClaro}"
                BorderThickness="1"
                CornerRadius="{StaticResource FlexoRadius_MD}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Grid.Row="0"
                        Height="40"
                        Style="{StaticResource FlexoGridHeaderStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="100" />
                            <ColumnDefinition
                                Width="90" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="120" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="80" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="ORDEN"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="FECHA"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="2"
                            Text="CLIENTE"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="3"
                            Text="TECNICO"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="4"
                            Text="APLICACION"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="5"
                            Text="TOTAL"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="6"
                            Text="ESTADO"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                        <TextBlock
                            Grid.Column="7"
                            Text="ACCION"
                            Style="{StaticResource FlexoGridHeaderTextStyle}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <TextBlock
                            x:Name="EmptyStateText"
                            Text="Sin ordenes para mostrar."
                            Style="{StaticResource FlexoTableCellStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                        <ListBox
                            x:Name="OrdersListBox"
                            Background="Transparent"
                            BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource FlexoDataGridRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="110" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding OrderNumber}" Style="{StaticResource FlexoTableCellStyle}" Foreground="{StaticResource FlexoRojo}" />
                                            <TextBlock Grid.Column="1" Text="{Binding DateText}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <TextBlock Grid.Column="2" Text="{Binding CustomerDisplayName}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <TextBlock Grid.Column="3" Text="{Binding EmployeeDisplayName}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <TextBlock Grid.Column="4" Text="{Binding ApplicationLabel}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <TextBlock Grid.Column="5" Text="{Binding TotalText}" Style="{StaticResource FlexoTableCellStyle}" />
                                            <Border Grid.Column="6" Style="{StaticResource FlexoBadgeStyle}" Background="{StaticResource FlexoAzulClaro}">
                                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource FlexoBlanco}" FontSize="{StaticResource FlexoFontSize_XS}" />
                                            </Border>
                                            <Button
                                                Grid.Column="7"
                                                Content="FACTURAR"
                                                Style="{StaticResource FlexoWindowButtonStyle}"
                                                Click="OnCompleteOrderClick" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
